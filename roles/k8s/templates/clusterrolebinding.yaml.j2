---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: {{ k8s_rbac_resource_name }}
  labels:
    app.kubernetes.io/name: {{ k8s_rbac_resource_name }}
    app.kubernetes.io/part-of: {{ k8s_rbac_part_of }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: {{ k8s_rbac_resource_name }}
subjects:
  - kind: ServiceAccount
    name: {{ k8s_rbac_resource_name }}
    namespace: {{ k8s_namespace }}
