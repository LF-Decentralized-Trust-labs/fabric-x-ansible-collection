---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: {{ k8s_rbac_resource_name }}
  labels:
    app.kubernetes.io/name: {{ k8s_rbac_resource_name }}
    app.kubernetes.io/part-of: {{ k8s_rbac_part_of }}
rules:
  - apiGroups: {{ k8s_rbac_clusterrole_api_groups | default([]) }}
{% if k8s_rbac_clusterrole_resources is defined %}
    resources: {{ k8s_rbac_clusterrole_resources }}
{% endif %}
{% if k8s_rbac_clusterrole_verbs is defined %}
    verbs: {{ k8s_rbac_clusterrole_verbs }}
{% endif %}
