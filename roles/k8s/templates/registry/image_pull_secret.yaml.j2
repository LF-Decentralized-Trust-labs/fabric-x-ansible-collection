apiVersion: v1
kind: Secret
metadata:
  name: {{ k8s_image_pull_secret }}
  namespace: {{ k8s_namespace }}
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: >-
    {{
      {
        'auths': {
          k8s_registry_url: {
            'username': k8s_registry_username,
            'password': k8s_registry_password,
            'auth': (k8s_registry_username ~ ':' ~ k8s_registry_password) | b64encode
          }
        }
      } | to_json | b64encode
    }}
