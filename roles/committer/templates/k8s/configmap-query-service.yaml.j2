---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ committer_k8s_resource_name }}-config
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ committer_k8s_resource_name }}
    app.kubernetes.io/component: {{ committer_component_type }}
    app.kubernetes.io/part-of: fabric-x-committer
data:
  # Main query-service configuration passed via --config at startup.
  config-query-service.yml: |
    {{ lookup('file', committer_remote_config_dir + '/' + committer_config_file) | indent(4) }}
{% if postgres_db_host is defined and hostvars[postgres_db_host].postgres_use_tls is defined and hostvars[postgres_db_host].postgres_use_tls %}
  # Postgres DB TLS CA certificate used to verify the database connection.
  tls-db-ca.crt: |
    {{ lookup('file', committer_k8s_db_ca_path) | indent(4) }}
{% elif yugabyte_cluster_ref_id is defined %}
{% set yugabyte_cluster_ref_host = groups['all'] | map('extract', hostvars) | selectattr('yugabyte_cluster_id', 'defined') | selectattr('yugabyte_cluster_id', '==', yugabyte_cluster_ref_id) | map(attribute='inventory_hostname') | first %}
{% if hostvars[yugabyte_cluster_ref_host].yugabyte_use_tls is defined and hostvars[yugabyte_cluster_ref_host].yugabyte_use_tls %}
  # YugabyteDB TLS CA certificate used to verify the database connection.
  tls-db-ca.crt: |
    {{ lookup('file', committer_k8s_db_ca_path) | indent(4) }}
{% endif %}
{% endif %}
{% if committer_monitoring_use_mtls and committer_monitoring_mtls_clients is defined %}
{% for committer_monitoring_mtls_client in committer_monitoring_mtls_clients %}
{% if committer_monitoring_mtls_client not in (committer_mtls_clients | default([])) %}
  # mTLS monitoring CA cert for client {{ committer_monitoring_mtls_client }}.
  mtls-client-{{ committer_monitoring_mtls_client }}-ca.crt: |
    {{ lookup('file', committer_remote_config_dir + '/mtls/' + committer_monitoring_mtls_client + '/ca.crt') | indent(4) }}
{% endif %}
{% endfor %}
{% endif %}
{% if committer_monitoring_use_mtls and committer_monitoring_mtls_orgs is defined %}
{% for committer_monitoring_mtls_org in committer_monitoring_mtls_orgs %}
{% if committer_monitoring_mtls_org not in (committer_mtls_orgs | default([])) %}
  # mTLS monitoring CA cert for org {{ committer_monitoring_mtls_org.domain }}.
  mtls-org-{{ committer_monitoring_mtls_org.domain }}-ca.crt: |
    {{ lookup('file', committer_remote_config_dir + '/mtls/' + committer_monitoring_mtls_org.domain + '/ca.crt') | indent(4) }}
{% endif %}
{% endfor %}
{% endif %}
{% if committer_use_mtls and committer_mtls_clients is defined %}
{% for current_mtls_client in committer_mtls_clients %}
  # mTLS CA cert for client {{ current_mtls_client }}.
  mtls-client-{{ current_mtls_client }}-ca.crt: |
    {{ lookup('file', committer_remote_config_dir + '/mtls/' + current_mtls_client + '/ca.crt') | indent(4) }}
{% endfor %}
{% endif %}
{% if committer_use_mtls and committer_mtls_orgs is defined %}
{% for current_mtls_org in committer_mtls_orgs %}
  # mTLS CA cert for org {{ current_mtls_org.domain }}.
  mtls-org-{{ current_mtls_org.domain }}-ca.crt: |
    {{ lookup('file', committer_remote_config_dir + '/mtls/' + current_mtls_org.domain + '/ca.crt') | indent(4) }}
{% endfor %}
{% endif %}
