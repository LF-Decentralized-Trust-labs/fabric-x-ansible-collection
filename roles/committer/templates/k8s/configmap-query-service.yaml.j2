---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ committer_k8s_resource_name }}-config
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ committer_k8s_resource_name }}
    app.kubernetes.io/component: {{ committer_component_type }}
    app.kubernetes.io/part-of: fabric-x-committer
data:
  # Main query-service configuration passed via --config at startup.
  config-query-service.yml: |
    {{ committer_k8s_config_content | indent(4) }}
{% if hostvars[postgres_db_host].postgres_use_tls is defined and hostvars[postgres_db_host].postgres_use_tls %}
  # Postgres DB TLS CA certificate used to verify the database connection.
  tls-db-ca.crt: |
    {{ lookup('file', committer_k8s_db_ca_path) | indent(4) }}
{% endif %}
{% for cert in committer_k8s_mtls_client_certs | default([]) %}
  # mTLS CA cert for client {{ cert.name }}.
  mtls-client-{{ cert.name }}-ca.crt: |
    {{ lookup('file', cert.path) | indent(4) }}
{% endfor %}
{% for cert in committer_k8s_mtls_org_certs | default([]) %}
  # mTLS CA cert for org {{ cert.domain }}.
  mtls-org-{{ cert.domain }}-ca.crt: |
    {{ lookup('file', cert.path) | indent(4) }}
{% endfor %}
