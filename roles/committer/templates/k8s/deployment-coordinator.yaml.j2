---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ committer_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ committer_k8s_resource_name }}
    app.kubernetes.io/component: {{ committer_component_type }}
    app.kubernetes.io/part-of: fabric-x-committer
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ committer_k8s_resource_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ committer_k8s_resource_name }}
        app.kubernetes.io/component: {{ committer_component_type }}
        app.kubernetes.io/part-of: fabric-x-committer
    spec:
      securityContext:
        fsGroup: {{ committer_k8s_fs_group }}
      containers:
        - name: {{ committer_component_type }}
          image: {{ committer_image }}
          args:
            - "committer"
            - "start-coordinator"
            - "--config={{ committer_container_config_dir }}/{{ committer_config_file }}"
          ports:
            - name: rpc
              containerPort: {{ committer_rpc_port }}
              protocol: TCP
            - name: metrics
              containerPort: {{ committer_metrics_port }}
              protocol: TCP
          volumeMounts:
            # Main coordinator configuration file.
            - name: config
              mountPath: {{ committer_container_config_dir }}/{{ committer_config_file }}
              subPath: config-coordinator.yml
{% if committer_use_tls %}
            # TLS private key.
            - name: secret
              mountPath: {{ committer_container_config_dir }}/tls/server.key
              subPath: tls-server.key
              readOnly: true
            # TLS server certificate.
            - name: secret
              mountPath: {{ committer_container_config_dir }}/tls/server.crt
              subPath: tls-server.crt
              readOnly: true
            # TLS CA certificate (also used for mTLS client trust).
            - name: secret
              mountPath: {{ committer_container_config_dir }}/tls/ca.crt
              subPath: tls-ca.crt
              readOnly: true
{% endif %}
{% if hostvars[committer_validator_ref_host].committer_use_tls is defined and hostvars[committer_validator_ref_host].committer_use_tls %}
            # TLS CA certificate of the validators (upstream servers).
            - name: config
              mountPath: {{ committer_container_config_dir }}/tls/validators/ca.crt
              subPath: tls-validators-ca.crt
              readOnly: true
{% endif %}
{% if hostvars[committer_verifier_ref_host].committer_use_tls is defined and hostvars[committer_verifier_ref_host].committer_use_tls %}
            # TLS CA certificate of the verifiers (upstream servers).
            - name: config
              mountPath: {{ committer_container_config_dir }}/tls/verifiers/ca.crt
              subPath: tls-verifiers-ca.crt
              readOnly: true
{% endif %}
{% if committer_use_mtls and committer_mtls_clients is defined %}
{% for client in committer_mtls_clients %}
            # mTLS CA cert for client {{ client }}.
            - name: config
              mountPath: {{ committer_container_config_dir }}/mtls/{{ client }}/ca.crt
              subPath: mtls-client-{{ client }}-ca.crt
              readOnly: true
{% endfor %}
{% endif %}
{% if committer_use_mtls and committer_mtls_orgs is defined %}
{% for org in committer_mtls_orgs %}
            # mTLS CA cert for org {{ org.domain }}.
            - name: config
              mountPath: {{ committer_container_config_dir }}/mtls/{{ org.domain }}/ca.crt
              subPath: mtls-org-{{ org.domain }}-ca.crt
              readOnly: true
{% endfor %}
{% endif %}
          readinessProbe:
            tcpSocket:
              port: {{ committer_metrics_port }}
            initialDelaySeconds: {{ k8s_readiness_probe_initial_delay_seconds | default(10) }}
            periodSeconds: {{ k8s_readiness_probe_period_seconds | default(10) }}
            timeoutSeconds: {{ k8s_readiness_probe_timeout_seconds | default(5) }}
            failureThreshold: {{ k8s_readiness_probe_failure_threshold | default(3) }}
            successThreshold: 1
          livenessProbe:
            tcpSocket:
              port: {{ committer_metrics_port }}
            initialDelaySeconds: {{ k8s_liveness_probe_initial_delay_seconds | default(30) }}
            periodSeconds: {{ k8s_liveness_probe_period_seconds | default(15) }}
            timeoutSeconds: {{ k8s_liveness_probe_timeout_seconds | default(5) }}
            failureThreshold: {{ k8s_liveness_probe_failure_threshold | default(5) }}
            successThreshold: 1
      volumes:
        - name: config
          configMap:
            name: {{ committer_k8s_resource_name }}-config
            defaultMode: 0640
{% if committer_use_tls %}
        - name: secret
          secret:
            secretName: {{ committer_k8s_resource_name }}-secret
            defaultMode: 0640
{% endif %}
{% if k8s_image_pull_secret is defined and k8s_image_pull_secret %}
      imagePullSecrets:
        - name: {{ k8s_image_pull_secret }}
{% endif %}
