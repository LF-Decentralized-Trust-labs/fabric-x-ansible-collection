---
apiVersion: v1
kind: Service
metadata:
  name: {{ committer_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ committer_k8s_resource_name }}
    app.kubernetes.io/component: {{ committer_component_type }}
    app.kubernetes.io/part-of: fabric-x-committer
spec:
{% if committer_component_type == 'sidecar' %}
  # Headless Service — required by the StatefulSet for stable DNS-based pod addressing.
  clusterIP: None
{% endif %}
  selector:
    app.kubernetes.io/name: {{ committer_k8s_resource_name }}
  ports:
    - name: rpc
      port: {{ committer_rpc_port }}
      targetPort: {{ committer_rpc_port }}
    - name: metrics
      port: {{ committer_metrics_port }}
      targetPort: {{ committer_metrics_port }}
