---
apiVersion: v1
kind: Service
metadata:
  # NodePort Service — exposes the committer component outside the cluster.
  name: {{ committer_k8s_resource_name }}-nodeport
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ committer_k8s_resource_name }}
    app.kubernetes.io/component: {{ committer_component_type }}
    app.kubernetes.io/part-of: fabric-x-committer
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: {{ committer_k8s_resource_name }}
  ports:
    - name: rpc
      port: {{ committer_rpc_port }}
      targetPort: {{ committer_rpc_port }}
      nodePort: {{ committer_k8s_rpc_node_port }}
    - name: metrics
      port: {{ committer_metrics_port }}
      targetPort: {{ committer_metrics_port }}
      nodePort: {{ committer_k8s_metrics_node_port }}
