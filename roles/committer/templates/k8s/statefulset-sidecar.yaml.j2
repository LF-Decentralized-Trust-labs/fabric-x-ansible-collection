---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ committer_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ committer_k8s_resource_name }}
    app.kubernetes.io/component: {{ committer_component_type }}
    app.kubernetes.io/part-of: {{ committer_k8s_part_of }}
spec:
  # Must match the headless Service name so DNS-based pod addressing works.
  serviceName: {{ committer_k8s_resource_name }}
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ committer_k8s_resource_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ committer_k8s_resource_name }}
        app.kubernetes.io/component: {{ committer_component_type }}
        app.kubernetes.io/part-of: {{ committer_k8s_part_of }}
    spec:
      securityContext:
        fsGroup: {{ committer_k8s_fs_group }}
      containers:
        - name: {{ committer_component_type }}
          image: {{ committer_image }}
          args:
            - "start-sidecar"
            - "--config={{ committer_container_config_dir }}/{{ committer_config_file }}"
          ports:
            - name: rpc
              containerPort: {{ committer_rpc_port }}
              protocol: TCP
            - name: metrics
              containerPort: {{ committer_metrics_port }}
              protocol: TCP
          volumeMounts:
            # Main sidecar configuration file.
            - name: config
              mountPath: {{ committer_container_config_dir }}/{{ committer_config_file }}
              subPath: config-sidecar.yml
{% if committer_use_tls %}
            # TLS private key.
            - name: secret
              mountPath: {{ committer_container_config_dir }}/tls/server.key
              subPath: tls-server.key
              readOnly: true
            # TLS server certificate.
            - name: secret
              mountPath: {{ committer_container_config_dir }}/tls/server.crt
              subPath: tls-server.crt
              readOnly: true
            # TLS CA certificate (also used for mTLS client trust).
            - name: secret
              mountPath: {{ committer_container_config_dir }}/tls/ca.crt
              subPath: tls-ca.crt
              readOnly: true
{% endif %}
{% if hostvars[committer_coordinator].committer_use_tls is defined and hostvars[committer_coordinator].committer_use_tls %}
            # TLS CA certificate of the coordinator (upstream server).
            - name: config
              mountPath: {{ committer_container_config_dir }}/tls/coordinator/ca.crt
              subPath: tls-coordinator-ca.crt
              readOnly: true
{% endif %}
{% for assembler in orderer_assemblers %}
{% if hostvars[assembler].orderer_use_tls is defined and hostvars[assembler].orderer_use_tls %}
            # TLS CA certificate of orderer assembler {{ assembler }}.
            - name: config
              mountPath: {{ committer_container_config_dir }}/tls/orderers/{{ assembler }}/ca.crt
              subPath: tls-orderers-{{ assembler }}-ca.crt
              readOnly: true
            # TLS server certificate of orderer assembler {{ assembler }} (per-org ca-cert-paths).
            - name: config
              mountPath: {{ committer_container_config_dir }}/tls/orderers/{{ assembler }}/server.crt
              subPath: tls-orderers-{{ assembler }}-server.crt
              readOnly: true
{% endif %}
{% endfor %}
            # MSP signing certificate.
            - name: secret
              mountPath: {{ committer_container_config_dir }}/msp/signcerts/cert.pem
              subPath: msp-signcerts-cert.pem
              readOnly: true
            # MSP private key.
            - name: secret
              mountPath: {{ committer_container_config_dir }}/msp/keystore/priv_sk
              subPath: msp-keystore-priv-sk
              readOnly: true
            # MSP CA certificate. The filename must match the
            # Certificate reference inside msp/config.yaml so that Fabric's
            # NodeOUs resolution can locate it at runtime.
            - name: secret
              mountPath: {{ committer_container_config_dir }}/msp/cacerts/ca.{{ organization.domain }}-cert.pem
              subPath: msp-cacerts-ca.pem
              readOnly: true
            # NodeOUs configuration: tells Fabric to classify identities by OU.
            - name: secret
              mountPath: {{ committer_container_config_dir }}/msp/config.yaml
              subPath: msp-config.yaml
              readOnly: true
{% if committer_monitoring_use_mtls and committer_monitoring_mtls_clients is defined %}
{% for committer_monitoring_mtls_client in committer_monitoring_mtls_clients %}
{% if committer_monitoring_mtls_client not in (committer_mtls_clients | default([])) %}
            # mTLS monitoring CA cert for client {{ committer_monitoring_mtls_client }}.
            - name: config
              mountPath: {{ committer_container_config_dir }}/mtls/{{ committer_monitoring_mtls_client }}/ca.crt
              subPath: mtls-client-{{ committer_monitoring_mtls_client }}-ca.crt
              readOnly: true
{% endif %}
{% endfor %}
{% endif %}
{% if committer_monitoring_use_mtls and committer_monitoring_mtls_orgs is defined %}
{% for committer_monitoring_mtls_org in committer_monitoring_mtls_orgs %}
{% if committer_monitoring_mtls_org not in (committer_mtls_orgs | default([])) %}
            # mTLS monitoring CA cert for org {{ committer_monitoring_mtls_org.domain }}.
            - name: config
              mountPath: {{ committer_container_config_dir }}/mtls/{{ committer_monitoring_mtls_org.domain }}/ca.crt
              subPath: mtls-org-{{ committer_monitoring_mtls_org.domain }}-ca.crt
              readOnly: true
{% endif %}
{% endfor %}
{% endif %}
{% if committer_use_mtls and committer_mtls_clients is defined %}
{% for current_mtls_client in committer_mtls_clients %}
            # mTLS CA cert for client {{ current_mtls_client }}.
            - name: config
              mountPath: {{ committer_container_config_dir }}/mtls/{{ current_mtls_client }}/ca.crt
              subPath: mtls-client-{{ current_mtls_client }}-ca.crt
              readOnly: true
{% endfor %}
{% endif %}
{% if committer_use_mtls and committer_mtls_orgs is defined %}
{% for current_mtls_org in committer_mtls_orgs %}
            # mTLS CA cert for org {{ current_mtls_org.domain }}.
            - name: config
              mountPath: {{ committer_container_config_dir }}/mtls/{{ current_mtls_org.domain }}/ca.crt
              subPath: mtls-org-{{ current_mtls_org.domain }}-ca.crt
              readOnly: true
{% endfor %}
{% endif %}
            # Persistent volume for the ledger.
            - name: data
              mountPath: {{ committer_container_data_dir }}
          readinessProbe:
            tcpSocket:
              port: {{ committer_metrics_port }}
            initialDelaySeconds: {{ k8s_readiness_probe_initial_delay_seconds | default(10) }}
            periodSeconds: {{ k8s_readiness_probe_period_seconds | default(10) }}
            timeoutSeconds: {{ k8s_readiness_probe_timeout_seconds | default(5) }}
            failureThreshold: {{ k8s_readiness_probe_failure_threshold | default(3) }}
            successThreshold: 1
          livenessProbe:
            tcpSocket:
              port: {{ committer_metrics_port }}
            initialDelaySeconds: {{ k8s_liveness_probe_initial_delay_seconds | default(30) }}
            periodSeconds: {{ k8s_liveness_probe_period_seconds | default(15) }}
            timeoutSeconds: {{ k8s_liveness_probe_timeout_seconds | default(5) }}
            failureThreshold: {{ k8s_liveness_probe_failure_threshold | default(5) }}
            successThreshold: 1
      volumes:
        - name: config
          configMap:
            name: {{ committer_k8s_resource_name }}-config
            defaultMode: 0640
        - name: secret
          secret:
            secretName: {{ committer_k8s_resource_name }}-secret
            defaultMode: 0640
{% if k8s_image_pull_secret is defined and k8s_image_pull_secret %}
      imagePullSecrets:
        - name: {{ k8s_image_pull_secret }}
{% endif %}
  volumeClaimTemplates:
    # PVC name — Kubernetes appends the pod ordinal (e.g. data-<name>-0).
    - metadata:
        name: data
      spec:
        accessModes:
          - ReadWriteOnce
{% if k8s_storage_class is defined and k8s_storage_class %}
        storageClassName: {{ k8s_storage_class }}
{% endif %}
        resources:
          requests:
            storage: {{ k8s_storage_size }}
