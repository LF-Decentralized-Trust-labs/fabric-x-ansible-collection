---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ committer_k8s_resource_name }}-config
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ committer_k8s_resource_name }}
    app.kubernetes.io/component: {{ committer_component_type }}
    app.kubernetes.io/part-of: fabric-x-committer
data:
  # Main sidecar configuration passed via --config at startup.
  config-sidecar.yml: |
    {{ lookup('file', committer_remote_config_dir + '/' + committer_sidecar_config_file) | indent(4) }}
{% if hostvars[committer_coordinator].committer_use_tls is defined and hostvars[committer_coordinator].committer_use_tls %}
  # TLS CA certificate of the coordinator (used for upstream TLS).
  tls-coordinator-ca.crt: |
    {{ lookup('file', committer_k8s_coordinator_ca_path) | indent(4) }}
{% endif %}
{% for current_orderer_assembler in orderer_assemblers %}
{% if hostvars[current_orderer_assembler].orderer_use_tls is defined and hostvars[current_orderer_assembler].orderer_use_tls %}
  # TLS CA certificate of orderer assembler {{ current_orderer_assembler }}.
  tls-orderers-{{ current_orderer_assembler }}-ca.crt: |
    {{ lookup('file', fetched_artifacts_dir + '/' + current_orderer_assembler + '/tls/ca.crt') | indent(4) }}
{% endif %}
{% endfor %}
{% if committer_use_mtls and committer_mtls_clients is defined %}
{% for current_mtls_client in committer_mtls_clients %}
  # mTLS CA cert for client {{ current_mtls_client }}.
  mtls-client-{{ current_mtls_client }}-ca.crt: |
    {{ lookup('file', committer_remote_config_dir + '/mtls/' + current_mtls_client + '/ca.crt') | indent(4) }}
{% endfor %}
{% endif %}
{% if committer_use_mtls and committer_mtls_orgs is defined %}
{% for current_mtls_org in committer_mtls_orgs %}
  # mTLS CA cert for org {{ current_mtls_org.domain }}.
  mtls-org-{{ current_mtls_org.domain }}-ca.crt: |
    {{ lookup('file', committer_remote_config_dir + '/mtls/' + current_mtls_org.domain + '/ca.crt') | indent(4) }}
{% endfor %}
{% endif %}
