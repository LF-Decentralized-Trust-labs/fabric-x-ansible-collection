---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ committer_k8s_resource_name }}-config
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ committer_k8s_resource_name }}
    app.kubernetes.io/component: {{ committer_component_type }}
    app.kubernetes.io/part-of: fabric-x-committer
data:
  # Main sidecar configuration passed via --config at startup.
  config-sidecar.yml: |
    {{ committer_k8s_config_content | indent(4) }}
{% if hostvars[committer_coordinator].committer_use_tls is defined and hostvars[committer_coordinator].committer_use_tls %}
  # TLS CA certificate of the coordinator (used for upstream TLS).
  tls-coordinator-ca.crt: |
    {{ lookup('file', committer_k8s_coordinator_ca_path) | indent(4) }}
{% endif %}
{% for cert in committer_k8s_orderer_assembler_cas | default([]) %}
  # TLS CA certificate of orderer assembler {{ cert.name }}.
  tls-orderers-{{ cert.name }}-ca.crt: |
    {{ lookup('file', cert.path) | indent(4) }}
{% endfor %}
{% for cert in committer_k8s_mtls_client_certs | default([]) %}
  # mTLS CA cert for client {{ cert.name }}.
  mtls-client-{{ cert.name }}-ca.crt: |
    {{ lookup('file', cert.path) | indent(4) }}
{% endfor %}
{% for cert in committer_k8s_mtls_org_certs | default([]) %}
  # mTLS CA cert for org {{ cert.domain }}.
  mtls-org-{{ cert.domain }}-ca.crt: |
    {{ lookup('file', cert.path) | indent(4) }}
{% endfor %}
