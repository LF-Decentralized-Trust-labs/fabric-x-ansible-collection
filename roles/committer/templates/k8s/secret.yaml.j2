---
apiVersion: v1
kind: Secret
metadata:
  name: {{ committer_k8s_resource_name }}-secret
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ committer_k8s_resource_name }}
    app.kubernetes.io/component: {{ committer_component_type }}
    app.kubernetes.io/part-of: fabric-x-committer
type: Opaque
data:
{% if committer_use_tls %}
  # TLS private key used to authenticate this committer component during the TLS handshake.
  tls-server.key: {{ lookup('file', committer_k8s_tls_server_key_path, rstrip=False) | b64encode }}
  # TLS server certificate presented to connecting clients.
  tls-server.crt: {{ lookup('file', committer_k8s_tls_server_crt_path, rstrip=False) | b64encode }}
  # TLS CA certificate used to verify incoming TLS connections (also used for mTLS client trust).
  tls-ca.crt: {{ lookup('file', committer_k8s_tls_ca_crt_path, rstrip=False) | b64encode }}
{% endif %}
{% if committer_component_type == 'sidecar' %}
  # MSP signing certificate (identity for orderer requests).
  msp-signcerts-cert.pem: {{ lookup('file', committer_k8s_msp_signcerts_path, rstrip=False) | b64encode }}
  # MSP private key.
  msp-keystore-priv-sk: {{ lookup('file', committer_k8s_msp_keystore_path, rstrip=False) | b64encode }}
  # MSP CA certificate.
  msp-cacerts-ca.pem: {{ lookup('file', committer_k8s_msp_cacerts_path, rstrip=False) | b64encode }}
  # NodeOUs config: enables OU-based identity classification (admin, orderer, peer, client)
  msp-config.yaml: {{ lookup('file', committer_k8s_msp_config_path, rstrip=False) | b64encode }}
{% endif %}
