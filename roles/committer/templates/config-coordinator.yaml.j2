# ---------------------------------------------------------------------------
# Verifier connection settings
# ---------------------------------------------------------------------------
verifier:
  # List of verifier service endpoints. Multiple endpoints enable load distribution
  # across verifier instances.
  endpoints:
{% for host in committer_verifiers %}
    - {{ hostvars[host].ansible_host }}:{{ hostvars[host].committer_rpc_port }}
{% endfor %}
{% if (hostvars[committer_verifier_ref_host].committer_use_tls is defined) and hostvars[committer_verifier_ref_host].committer_use_tls %}
  # Define TLS options and certificate paths used for secure communication
  # between the coordinator and the verifiers.
  tls:
    # List of paths to CA certificate files for verifying server certificates.
    ca-cert-paths:
      - {{ committer_config_dir }}/tls/verifiers/ca.crt
    # TODO: currently this section must be set even for TLS only: https://github.com/hyperledger/fabric-x-committer/pull/464
    # Path to the client's TLS private key file.
    key-path: {{ committer_config_dir }}/tls/server.key
    # Path to the client's TLS certificate file (public key) for authentication.
    cert-path: {{ committer_config_dir }}/tls/server.crt
{% if (hostvars[committer_verifier_ref_host].committer_use_mtls is defined) and hostvars[committer_verifier_ref_host].committer_use_mtls %}
    # TLS mode for client connections to verifier: 'none' (no TLS), 'tls' (server auth only),
    # or 'mtls' (mutual TLS with client cert verification).
    mode: mtls
{% else %}
    # TLS mode for client connections to verifier: 'none' (no TLS), 'tls' (server auth only),
    # or 'mtls' (mutual TLS with client cert verification).
    mode: tls
{% endif %}
{% endif %}

# ---------------------------------------------------------------------------
# Validator-committer connection settings
# ---------------------------------------------------------------------------
validator-committer:
  # List of validator-committer (VC) service endpoints. Multiple endpoints enable
  # load distribution across VC instances.
  endpoints:
{% for host in committer_validators %}
    - {{ hostvars[host].ansible_host }}:{{ hostvars[host].committer_rpc_port }}
{% endfor %}
{% if (hostvars[committer_validator_ref_host].committer_use_tls is defined) and hostvars[committer_validator_ref_host].committer_use_tls %}
  # Define TLS options and certificate paths used for secure communication
  # between the coordinator and the validators.
  tls:
    # List of paths to CA certificate files for verifying server certificates.
    ca-cert-paths:
      - {{ committer_config_dir }}/tls/validators/ca.crt
    # TODO: currently this section must be set even for TLS only: https://github.com/hyperledger/fabric-x-committer/pull/464
    # Path to the client's TLS private key file.
    key-path: {{ committer_config_dir }}/tls/server.key
    # Path to the client's TLS certificate file (public key) for authentication.
    cert-path: {{ committer_config_dir }}/tls/server.crt
{% if (hostvars[committer_validator_ref_host].committer_use_mtls is defined) and hostvars[committer_validator_ref_host].committer_use_mtls %}
    # TLS mode for client connections to validator-committer: 'none' (no TLS), 'tls' (server auth only),
    # or 'mtls' (mutual TLS with client cert verification).
    mode: mtls
{% else %}
    # TLS mode for client connections to validator-committer: 'none' (no TLS), 'tls' (server auth only),
    # or 'mtls' (mutual TLS with client cert verification).
    mode: tls
{% endif %}
{% endif %}

# ---------------------------------------------------------------------------
# Dependency graph settings
# ---------------------------------------------------------------------------
dependency-graph:
  # Number of transaction batches that can be processed in parallel to construct
  # batch-level (local) dependency graphs. Higher values enable parallel processing
  # of multiple batches but increase CPU usage.
  num-of-local-dep-constructors: {{ committer_coordinator_dep_graph_constructors | default(4) }}
  # Maximum number of transactions allowed in the global dependency graph.
  # This limit indirectly controls memory utilization. When reached, the
  # coordinator applies backpressure to upstream services.
  waiting-txs-limit: {{ committer_coordinator_dep_graph_wait_tx_limit | default(20000000) }}

# Base buffer size per goroutine/endpoint for internal channels. The actual
# buffer size is calculated as this value multiplied by the number of endpoints
# (for verifier/validator-committer managers) or the number of local dependency
# constructors. Larger values reduce contention but increase memory usage proportionally.
per-channel-buffer-size-per-goroutine: {{ committer_coordinator_per_channel_buffer_size_per_goroutine | default(10) }}
