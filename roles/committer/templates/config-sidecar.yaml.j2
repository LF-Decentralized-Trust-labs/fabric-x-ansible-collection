{% include './sections/server.yaml.j2' +%}
{% if committer_metrics_port is defined %}
{% include './sections/monitoring.yaml.j2' +%}
{% endif %}

{% include './sections/logging.yaml.j2' +%}

# ---------------------------------------------------------------------------
# HLFX Orderers connection settings
# The HLFX Committer Sidecar component pulls blocks from the ordering
# service.
# ---------------------------------------------------------------------------
orderer:
  # Channel ID
  channel-id: {{ channel_id }}
  # Consensus type of the ordering service: 'BFT' (Byzantine Fault Tolerant) or 'CFT' (Crash Fault Tolerant / Raft).
  # Defaults to 'CFT' if not specified. Affects how the sidecar interacts with orderers.
  consensus-type: BFT
  # Organizations map organization MSP IDs to their orderer connection details.
  # It supports multi-organization deployments where each org has its own orderers and TLS root CAs.
  # Each organization can have multiple orderer endpoints with different capabilities (broadcast, deliver).
  identity:
    # Indicates to which MSP this client belongs to.
    msp-id: {{ organization.name }}MSP
    # Indicates the MSP folder to use as identity
    msp-dir: {{ committer_config_dir }}/msp
    # BCCSP (Blockchain crypto provider): Select which crypto implementation or
    # library to use
    bccsp:
      Default: SW
      # Settings for the SW crypto provider (i.e. when DEFAULT: SW)
      SW:
        # The default Hash and Security level needs refactoring to be
        # fully configurable. Changing these defaults requires coordination
        # SHA2 is hardcoded in several places, not only BCCSP
        Security: 256
        Hash: SHA2  
  organizations:
{% for orderer_assembler in orderer_assemblers %}
    {{ hostvars[orderer_assembler].organization.name }}:
      endpoints:
        - id={{ hostvars[orderer_assembler].orderer_group }},deliver,{{ hostvars[orderer_assembler].ansible_host }}:{{ hostvars[orderer_assembler].orderer_rpc_port }}
{% if (hostvars[orderer_assembler_ref_host].orderer_use_tls is defined) and hostvars[orderer_assembler_ref_host].orderer_use_tls %}
      # List of paths to CA certificate files for verifying orderer certificates.
      # Each organization can have its own CA certificates.
      ca-cert-paths:
        - {{ committer_config_dir }}/tls/orderers/{{ orderer_assembler }}/server.crt
{% endif %}
{% endfor %}
{% if (hostvars[orderer_assembler_ref_host].orderer_use_tls is defined) and hostvars[orderer_assembler_ref_host].orderer_use_tls %}
  # Sidecar uses these TLS credentials when connecting to the orderers as a client.
  tls:
    # List of common CA certificate paths used across all orderer organizations.
    # These are in addition to organization-specific CA certificates.
    common-ca-cert-paths:
{% for orderer_assembler in orderer_assemblers %}
      - {{ committer_config_dir }}/tls/orderers/{{ orderer_assembler }}/ca.crt
{% endfor %}
{% if (hostvars[orderer_assembler_ref_host].orderer_use_mtls is defined) and hostvars[orderer_assembler_ref_host].orderer_use_mtls %}
    # Path to the TLS key file (private key).
    key-path: {{ committer_config_dir }}/tls/server.key
    # Path to the TLS certificate file (public key).
    cert-path: {{ committer_config_dir }}/tls/server.crt
    # TLS mode for orderer client connections: 'none' (no TLS), 'tls' (server auth only),
    # or 'mtls' (mutual TLS with client cert verification).
    mode: mtls
{% else %}
    # TLS configuration modes ("none", "tls" or "mtls")
    mode: tls
{% endif %}
{% endif %}

# ---------------------------------------------------------------------------
# HLFX Committer Coordinator connection settings
# The HLFX Committer Sidecar pushes the blocks to the HFLX Committer
# Coordinator and pulls from the latter the block statuses.
# ---------------------------------------------------------------------------
committer:
  # HLFX Committer Coordinator endpoint
  endpoint: {{ hostvars[committer_coordinator].ansible_host }}:{{ hostvars[committer_coordinator].committer_rpc_port }}
{% if (hostvars[committer_coordinator].committer_use_tls is defined) and hostvars[committer_coordinator].committer_use_tls %}
  # Define TLS options and certificate paths used for secure communication
  # between the sidecar and the coordinator.
  tls:
    # Server CA certificates to trust if tls is enabled.
    ca-cert-paths:
      - {{ committer_config_dir }}/tls/coordinator/ca.crt
{% if (hostvars[committer_coordinator].committer_use_mtls is defined) and hostvars[committer_coordinator].committer_use_mtls %}
    # Path to the TLS key file (private key).
    key-path: {{ committer_config_dir }}/tls/server.key
    # Path to the TLS certificate file (public key).
    cert-path: {{ committer_config_dir }}/tls/server.crt
    # TLS configuration modes ("none", "tls" or "mtls")
    mode: mtls
{% else %}
    # TLS configuration modes ("none", "tls" or "mtls")
    mode: tls
{% endif %}
{% endif %}

# ---------------------------------------------------------------------------
# Relay Settings
# ---------------------------------------------------------------------------
# Interval for setting the last committed block to the HLFX Committer Coordinator
last-committed-block-set-interval: {{ committer_sidecar_last_committed_block_set_interval | default('5s') }}
# maximum number of transaction allowed to wait in the sidecar
waiting-txs-limit: {{ committer_sidecar_waiting_txs_limit | default(20000000) }}
# capacity of the channel/queue used between various components (relay, ledger)
channel-buffer-size: {{ committer_sidecar_channel_buffer_size | default(100) }}

# ---------------------------------------------------------------------------
# Ledger settings
# ---------------------------------------------------------------------------
ledger:
  # Path where to store the ledger
  path: {{ committer_config_dir }}/ledger
  # How often the block store fsyncs to durable storage. Every Nth block triggers
  # a full sync; intermediate blocks are written without fsync. Set to 0 or 1 to
  # sync every block (safest but slowest). Higher values improve write performance
  # but risk losing more blocks on crash (recoverable from orderer).
  sync-interval: {{ committer_sidecar_ledger_sync_interval | default(100) }}

# ---------------------------------------------------------------------------
# Notification settings
# ---------------------------------------------------------------------------
notification:
  # Maximum time a client notification subscription can remain idle before being
  # automatically closed. Prevents resource leaks from abandoned subscriptions.
  # If a client doesn't specify a timeout, this value is used.
  max-timeout: {{ committer_sidecar_notification_max_timeout | default('10m') }}