# ---------------------------------------------------------------------------
# GRPC Server configuration
# ---------------------------------------------------------------------------
server:
  # The GRPC server endpoint
  endpoint: 0.0.0.0:{{ committer_rpc_port }}
  # Rate limiting configuration for unary gRPC endpoints.
  # Uses a token bucket algorithm to limit the number of requests per second.
  rate-limit:
    # Maximum number of requests per second allowed.
    # Set to 0 to disable rate limiting.
    requests-per-second: {{ committer_server_rate_limit_requests_per_second | default(0) }}
    # Maximum number of requests allowed in a single burst.
    # When rate limiting is enabled (requests-per-second > 0):
    #   - Must be greater than 0
    #   - Must be less than or equal to requests-per-second
    burst: {{ committer_server_rate_limit_burst | default(0) }}
  # Set the keepalive behavior for the gRPC server.
  keep-alive:
    params:
      # Duration after which the server sends a keepalive ping if no data has been
      # transmitted on the connection. Helps detect dead connections and prevent resource leaks.
      time: {{ committer_server_keep_alive_time | default('300s') }}
      # How long the server waits for a keepalive acknowledgment before closing the connection.
      # Should be longer than params.time to allow for network delays.
      timeout: {{ committer_server_keep_alive_timeout | default('600s') }}
    # Used to set keepalive enforcement policy on the server-side.
    # Server will close connection with a client that violates this policy.
    enforcement-policy:
      # Minimum time clients must wait between sending keepalive pings. Prevents clients
      # from overwhelming the server with excessive pings. Clients violating this are disconnected.
      min-time: {{ committer_server_keep_alive_min_time | default('60s') }}
      # Controls whether clients can send keepalive pings when no active streams exist.
      # Set to false to prevent unnecessary pings and reduce server load.
      permit-without-stream: {{ committer_server_keep_alive_permit_without_stream | default(false) | bool | lower }}
  # Maximum number of concurrent streaming RPCs (Deliver + Notification) allowed per
  # client connection. Limits resource usage but may cause connection failures if clients
  # need more streams. Set to 0 for unlimited (not recommended in production).
  max-concurrent-streams: {{ committer_server_max_concurrent_streams | default(0) }}
{% if committer_use_tls %}
  # Define TLS options and certificate paths used for secure communication
  # between servers and clients. Credentials are built based on the configuration mode.
  # For example, If only server-side TLS is required, the certificate pool (certPool)
  # is not built (for a server), since the relevant certificates paths are defined
  # in the YAML according to the selected mode.
  tls:
    # Path to the server's TLS private key file.
    key-path: {{ committer_config_dir }}/tls/server.key
    # Path to the server's TLS certificate file (public key).
    cert-path: {{ committer_config_dir }}/tls/server.crt
{% if committer_use_mtls %}
    # TLS mode for server connections: 'none' (no TLS), 'tls' (server auth only),
    # or 'mtls' (mutual TLS with client cert verification).
    mode: mtls
    # List of paths to CA certificate files for verifying client certificates (required for mtls).
    ca-cert-paths:
      # Accept mTLS connections from others within the same org
      - {{ committer_config_dir }}/tls/ca.crt
{% if committer_mtls_clients is defined %}
      # Other mTLS clients
{% for committer_mtls_client in committer_mtls_clients %}
      - {{ committer_config_dir }}/mtls/{{ committer_mtls_client }}/ca.crt
{% endfor %}
{% endif %}
{% if committer_mtls_orgs is defined %}
      # Other mTLS Orgs
{% for committer_mtls_org in committer_mtls_orgs %}
      - {{ committer_config_dir }}/mtls/{{ committer_mtls_org.domain }}/ca.crt
{% endfor %}
{% endif %}
{% else %}
    # TLS mode for server connections: 'none' (no TLS), 'tls' (server auth only),
    # or 'mtls' (mutual TLS with client cert verification).
    mode: tls
{% endif %}
{% endif %}
