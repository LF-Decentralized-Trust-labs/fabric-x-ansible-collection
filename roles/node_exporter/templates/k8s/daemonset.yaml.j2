---
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: {{ node_exporter_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ node_exporter_k8s_resource_name }}
    app.kubernetes.io/component: node-exporter
    app.kubernetes.io/part-of: {{ node_exporter_k8s_part_of }}
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ node_exporter_k8s_resource_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ node_exporter_k8s_resource_name }}
        app.kubernetes.io/component: node-exporter
        app.kubernetes.io/part-of: {{ node_exporter_k8s_part_of }}
    spec:
      # Tolerate all taints so node-exporter runs on every node in the cluster,
      # including control-plane and tainted worker nodes.
      tolerations:
        - operator: Exists
      containers:
        - name: node-exporter
          image: {{ node_exporter_image }}
          # Default runAsUser is 0 (root) to allow reading all host paths.
          # On OpenShift, set node_exporter_k8s_run_as_user to the namespace
          # UID range value; /proc and /sys are world-readable so core metrics
          # (CPU, memory, network, disk I/O) still work as non-root.
          securityContext:
            runAsUser: {{ node_exporter_k8s_run_as_user }}
            runAsNonRoot: {{ (node_exporter_k8s_run_as_user != 0) | lower }}
          args:
            - --web.listen-address=:{{ node_exporter_port }}
            # Point node-exporter at the host filesystem mounts so it reports
            # host-level metrics rather than container-level metrics.
            - --path.rootfs=/host/root
            - --path.procfs=/host/proc
            - --path.sysfs=/host/sys
{% if node_exporter_use_tls %}
            - --web.config.file={{ node_exporter_container_config_dir }}/{{ node_exporter_web_config_file }}
{% endif %}
          ports:
            - name: metrics
              containerPort: {{ node_exporter_port }}
              protocol: TCP
          volumeMounts:
            # Host root filesystem — needed by collectors such as filesystem and diskstats.
            - name: host-root
              mountPath: /host/root
              readOnly: true
            # Host /proc — needed for process, CPU, memory, and network collectors.
            - name: host-proc
              mountPath: /host/proc
              readOnly: true
            # Host /sys — needed for hardware (CPU frequency, block device) collectors.
            - name: host-sys
              mountPath: /host/sys
              readOnly: true
{% if node_exporter_use_tls %}
            # TLS server certificate.
            - name: secret
              mountPath: {{ node_exporter_container_config_dir }}/tls/{{ node_exporter_tls_cert_file }}
              subPath: {{ node_exporter_tls_cert_file }}
              readOnly: true
            # TLS private key.
            - name: secret
              mountPath: {{ node_exporter_container_config_dir }}/tls/{{ node_exporter_tls_private_key_file }}
              subPath: {{ node_exporter_tls_private_key_file }}
              readOnly: true
            # Web config (TLS settings, optional basic auth).
            - name: config
              mountPath: {{ node_exporter_container_config_dir }}/{{ node_exporter_web_config_file }}
              subPath: {{ node_exporter_web_config_file }}
              readOnly: true
{% endif %}
          readinessProbe:
            tcpSocket:
              port: {{ node_exporter_port }}
            initialDelaySeconds: {{ k8s_readiness_probe_initial_delay_seconds | default(10) }}
            periodSeconds: {{ k8s_readiness_probe_period_seconds | default(10) }}
            timeoutSeconds: {{ k8s_readiness_probe_timeout_seconds | default(5) }}
            failureThreshold: {{ k8s_readiness_probe_failure_threshold | default(3) }}
            successThreshold: 1
          livenessProbe:
            tcpSocket:
              port: {{ node_exporter_port }}
            initialDelaySeconds: {{ k8s_liveness_probe_initial_delay_seconds | default(30) }}
            periodSeconds: {{ k8s_liveness_probe_period_seconds | default(15) }}
            timeoutSeconds: {{ k8s_liveness_probe_timeout_seconds | default(5) }}
            failureThreshold: {{ k8s_liveness_probe_failure_threshold | default(5) }}
            successThreshold: 1
      volumes:
        # Mount the host root filesystem under /host/root (read-only).
        - name: host-root
          hostPath:
            path: /
            type: Directory
        # Mount the host /proc under /host/proc (read-only).
        - name: host-proc
          hostPath:
            path: /proc
            type: Directory
        # Mount the host /sys under /host/sys (read-only).
        - name: host-sys
          hostPath:
            path: /sys
            type: Directory
        # ConfigMap holds the web config file (TLS/auth settings).
        - name: config
          configMap:
            name: {{ node_exporter_k8s_resource_name }}
            defaultMode: 0640
        # Secret holds the TLS certificate and private key.
        - name: secret
          secret:
            secretName: {{ node_exporter_k8s_resource_name }}
            defaultMode: 0640
{% if k8s_image_pull_secret is defined and k8s_image_pull_secret %}
      imagePullSecrets:
        - name: {{ k8s_image_pull_secret }}
{% endif %}
