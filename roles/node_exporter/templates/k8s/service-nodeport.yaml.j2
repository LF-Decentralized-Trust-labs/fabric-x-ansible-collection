---
apiVersion: v1
kind: Service
metadata:
  name: {{ node_exporter_k8s_resource_name }}-nodeport
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ node_exporter_k8s_resource_name }}
    app.kubernetes.io/component: node-exporter
    app.kubernetes.io/part-of: monitoring
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: {{ node_exporter_k8s_resource_name }}
  ports:
{% if node_exporter_k8s_node_port is defined %}
    - name: metrics
      port: {{ node_exporter_port }}
      targetPort: metrics
      nodePort: {{ node_exporter_k8s_node_port }}
{% endif %}
