---
apiVersion: v1
kind: Service
metadata:
  # Headless Service -- required by the StatefulSet for stable DNS-based pod addressing.
  name: {{ elasticsearch_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ elasticsearch_k8s_resource_name }}
    app.kubernetes.io/part-of: {{ elasticsearch_k8s_part_of }}
spec:
  # clusterIP: None makes this a headless Service -- no virtual IP is assigned,
  # DNS resolves directly to the pod IP, which is needed by the StatefulSet.
  clusterIP: None
  selector:
    app.kubernetes.io/name: {{ elasticsearch_k8s_resource_name }}
  ports:
    # ElasticSearch HTTP REST API port.
    - name: http
      port: {{ elasticsearch_http_port }}
      targetPort: {{ elasticsearch_http_port }}
    # ElasticSearch transport port used for node-to-node communication.
    - name: transport
      port: {{ elasticsearch_transport_port }}
      targetPort: {{ elasticsearch_transport_port }}
