---
apiVersion: v1
kind: Service
metadata:
  # NodePort Service -- exposes ElasticSearch outside the cluster for external clients.
  name: {{ elasticsearch_k8s_resource_name }}-nodeport
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ elasticsearch_k8s_resource_name }}
    app.kubernetes.io/part-of: elasticsearch
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: {{ elasticsearch_k8s_resource_name }}
  ports:
    - name: http
      # nodePort matches port so external addresses are predictable.
      port: {{ elasticsearch_http_port }}
      targetPort: {{ elasticsearch_http_port }}
      nodePort: {{ elasticsearch_k8s_http_node_port }}
    - name: transport
      port: {{ elasticsearch_transport_port }}
      targetPort: {{ elasticsearch_transport_port }}
      nodePort: {{ elasticsearch_k8s_transport_node_port }}
