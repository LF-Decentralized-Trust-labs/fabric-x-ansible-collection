---
apiVersion: v1
kind: Secret
metadata:
  name: {{ elasticsearch_k8s_resource_name }}-secret
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ elasticsearch_k8s_resource_name }}
    app.kubernetes.io/part-of: {{ elasticsearch_k8s_part_of }}
type: Opaque
data:
{% if elasticsearch_use_tls %}
  # TLS private key used to authenticate this ElasticSearch node during the TLS handshake.
  tls-server.key: {{ lookup('file', elasticsearch_k8s_tls_server_key_path) | b64encode }}
  # TLS server certificate presented to connecting clients.
  tls-server.crt: {{ lookup('file', elasticsearch_k8s_tls_server_cert_path) | b64encode }}
  # TLS CA certificate used to verify incoming TLS connections.
  tls-ca.crt: {{ lookup('file', elasticsearch_k8s_tls_ca_cert_path) | b64encode }}
{% endif %}
