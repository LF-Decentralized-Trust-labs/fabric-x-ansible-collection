# Global configuration for Prometheus server
global:
  # How often to scrape metrics from targets (default 2 seconds)
  scrape_interval: {{ prometheus_scrape_interval }}

# List of scrape jobs (each defines a set of targets to monitor)
scrape_configs:
{% if prometheus_scrape_services is defined %}
{% for current_service_to_scrape in prometheus_scrape_services %}
{% if (current_service_to_scrape.targets | default([]) | map(attribute='hosts') | sum(start=[]) | length) > 0 or current_service_to_scrape.kubernetes_sd_configs is defined %}
  # Identifier for the scrape job
  - job_name: {{ current_service_to_scrape.job_name }}
{% if current_service_to_scrape.prometheus_metrics_path is defined %}
    # GET endpoint path to collect the metrics
    metrics_path: {{ current_service_to_scrape.prometheus_metrics_path }}
{% endif %}
{% if current_service_to_scrape.use_tls is defined and current_service_to_scrape.use_tls %}
    # TLS settings
    scheme: https
    tls_config:
      ca_file: {{ prometheus_container_config_dir }}/tls-{{ current_service_to_scrape.job_name }}-ca.crt
{% if current_service_to_scrape.use_mtls is defined and current_service_to_scrape.use_mtls %}
      cert_file: {{ prometheus_container_config_dir }}/tls/{{ prometheus_tls_cert_file }}
      key_file: {{ prometheus_container_config_dir }}/tls/{{ prometheus_tls_private_key_file }}
{% endif %}
{% endif %}
{% if current_service_to_scrape.relabel_configs is defined %}
    relabel_configs:
{% for relabel_config in current_service_to_scrape.relabel_configs %}
      - source_labels: {{ relabel_config.source_labels | default([]) }}
{% if relabel_config.action is defined %}
        action: {{ relabel_config.action }}
{% endif %}
{% if relabel_config.regex is defined %}
        regex: {{ relabel_config.regex }}
{% endif %}
{% if relabel_config.target_label is defined %}
        target_label: {{ relabel_config.target_label }}
{% endif %}
{% if relabel_config.replacement is defined %}
        replacement: {{ relabel_config.replacement }}
{% endif %}
{% endfor %}
{% endif %}
{% if current_service_to_scrape.metric_relabel_configs is defined %}
    metric_relabel_configs:
{% for metrics_relabel_config in current_service_to_scrape.metric_relabel_configs %}
      - source_labels: {{ metrics_relabel_config.source_labels }}
        regex: {{ metrics_relabel_config.regex | quote }}
        target_label: {{ metrics_relabel_config.target_label | quote }}
        replacement: {{ metrics_relabel_config.replacement | quote }}
{% endfor %}
{% endif %}
{% if current_service_to_scrape.kubernetes_sd_configs is defined %}
    # Kubernetes service discovery configuration
    kubernetes_sd_configs:
{% for sd_config in current_service_to_scrape.kubernetes_sd_configs %}
      - role: {{ sd_config.role }}
{% if sd_config.namespaces is defined %}
        namespaces:
{% if sd_config.namespaces.names is defined %}
          names:
{% for ns in sd_config.namespaces.names %}
            - {{ ns }}
{% endfor %}
{% endif %}
{% endif %}
{% endfor %}
{% else %}
    # Static list of targets for this job
    static_configs:
{% for targets in current_service_to_scrape.targets %}
      # List of targets to scrape
      - targets:
{% if targets.hosts is defined %}
{% for host in targets.hosts %}
        - {{ hostvars[host].ansible_host }}:{{ hostvars[host][targets.port_to_scrape] }}
{% endfor %}
{% endif %}
{% if targets.label is defined %}
        labels:
{% if targets.label.group is defined %}
          group: {{ targets.label.group }}
{% endif %}
{% if targets.label.export_type is defined %}
          export_type: {{ targets.label.export_type }}
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
