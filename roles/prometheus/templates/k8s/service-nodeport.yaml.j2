---
apiVersion: v1
kind: Service
metadata:
  name: {{ prometheus_k8s_resource_name }}-nodeport
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ prometheus_k8s_resource_name }}
    app.kubernetes.io/part-of: prometheus
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: {{ prometheus_k8s_resource_name }}
  ports:
    - name: http
      port: {{ prometheus_port }}
      targetPort: {{ prometheus_port }}
      nodePort: {{ prometheus_k8s_node_port }}
