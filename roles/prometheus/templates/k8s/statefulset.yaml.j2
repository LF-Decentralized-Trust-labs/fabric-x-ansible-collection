---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  # One StatefulSet per Prometheus instance.
  name: {{ prometheus_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ prometheus_k8s_resource_name }}
    app.kubernetes.io/part-of: {{ prometheus_k8s_part_of }}
spec:
  # Must match the headless Service name so DNS-based pod addressing works.
  serviceName: {{ prometheus_k8s_resource_name }}
  # Single-node Prometheus; scaling is done by adding nodes to the inventory.
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ prometheus_k8s_resource_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ prometheus_k8s_resource_name }}
        app.kubernetes.io/part-of: {{ prometheus_k8s_part_of }}
    spec:
      securityContext:
        # prom/prometheus runs as nobody (UID 65534), so fsGroup keeps mounted files readable.
        fsGroup: {{ prometheus_k8s_fs_group }}
      containers:
        - name: prometheus
          image: {{ prometheus_image }}
          args:
            - --web.listen-address=:{{ prometheus_port }}
            - --config.file={{ prometheus_container_config_dir }}/{{ prometheus_config_file }}
            - --storage.tsdb.path={{ prometheus_container_data_dir }}
            - --web.console.libraries=/usr/share/prometheus/console_libraries
            - --web.console.templates=/usr/share/prometheus/consoles
            - --web.enable-remote-write-receiver
            - --web.enable-lifecycle
            - --enable-feature=native-histograms
{% if prometheus_use_tls %}
            - --web.config.file={{ prometheus_container_config_dir }}/{{ prometheus_web_config_file }}
{% endif %}
          ports:
            - name: http
              containerPort: {{ prometheus_port }}
              protocol: TCP
          readinessProbe:
            httpGet:
              path: /-/ready
              port: http
              scheme: "{{ 'HTTPS' if prometheus_use_tls else 'HTTP' }}"
            initialDelaySeconds: {{ k8s_readiness_probe_initial_delay_seconds | default(10) }}
            periodSeconds: {{ k8s_readiness_probe_period_seconds | default(10) }}
            timeoutSeconds: {{ k8s_readiness_probe_timeout_seconds | default(5) }}
            failureThreshold: {{ k8s_readiness_probe_failure_threshold | default(6) }}
            successThreshold: 1
          livenessProbe:
            httpGet:
              path: /-/healthy
              port: http
              scheme: "{{ 'HTTPS' if prometheus_use_tls else 'HTTP' }}"
            initialDelaySeconds: {{ k8s_liveness_probe_initial_delay_seconds | default(30) }}
            periodSeconds: {{ k8s_liveness_probe_period_seconds | default(15) }}
            timeoutSeconds: {{ k8s_liveness_probe_timeout_seconds | default(10) }}
            failureThreshold: {{ k8s_liveness_probe_failure_threshold | default(10) }}
            successThreshold: 1
          volumeMounts:
            # Persistent TSDB storage.
            - name: data
              mountPath: {{ prometheus_container_data_dir }}
            # All Prometheus config files and TLS CA certs from the ConfigMap.
            - name: config
              mountPath: {{ prometheus_container_config_dir }}
              readOnly: true
{% if prometheus_use_tls %}
            # TLS keypair for the Prometheus HTTPS server.
            - name: secret
              mountPath: {{ prometheus_container_config_dir }}/tls
              readOnly: true
{% endif %}
      volumes:
        - name: config
          # ConfigMap holds Prometheus config and optional TLS CA certs for scrape targets.
          configMap:
            name: {{ prometheus_k8s_resource_name }}-config
            defaultMode: 0640
        - name: secret
          # Secret holds the server TLS key and certificate.
          secret:
            secretName: {{ prometheus_k8s_resource_name }}-secret
            defaultMode: 0640
{% if k8s_image_pull_secret is defined and k8s_image_pull_secret %}
      imagePullSecrets:
        - name: {{ k8s_image_pull_secret }}
{% endif %}
  volumeClaimTemplates:
    # PVC name: Kubernetes appends the pod ordinal, e.g. data-<name>-0.
    - metadata:
        name: data
      spec:
        accessModes:
          - ReadWriteOnce
{% if k8s_storage_class is defined and k8s_storage_class %}
        storageClassName: {{ k8s_storage_class }}
{% endif %}
        resources:
          requests:
            storage: {{ k8s_storage_size }}
