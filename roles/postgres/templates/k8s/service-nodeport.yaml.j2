---
apiVersion: v1
kind: Service
metadata:
  # NodePort Service — exposes PostgreSQL outside the cluster for external clients.
  name: {{ postgres_k8s_resource_name }}-nodeport
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ postgres_k8s_resource_name }}
    app.kubernetes.io/part-of: postgres
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: {{ postgres_k8s_resource_name }}
  ports:
    - name: postgres
      # nodePort matches port so external addresses are predictable.
      port: {{ postgres_port }}
      targetPort: {{ postgres_port }}
      nodePort: {{ postgres_k8s_port_node_port }}
