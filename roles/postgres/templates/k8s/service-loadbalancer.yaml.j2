---
apiVersion: v1
kind: Service
metadata:
  # LoadBalancer Service — exposes PostgreSQL outside the cluster for external clients.
  name: {{ postgres_k8s_resource_name }}-loadbalancer
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ postgres_k8s_resource_name }}
    app.kubernetes.io/part-of: postgres
spec:
  type: LoadBalancer
  selector:
    app.kubernetes.io/name: {{ postgres_k8s_resource_name }}
  ports:
    - name: postgres
      # Exposes PostgreSQL externally.
      port: {{ postgres_port }}
      targetPort: postgres
