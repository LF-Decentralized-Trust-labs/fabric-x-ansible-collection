---
apiVersion: v1
kind: Secret
metadata:
  name: {{ postgres_k8s_resource_name }}-secret
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ postgres_k8s_resource_name }}
    app.kubernetes.io/part-of: postgres
type: Opaque
data:
  # PostgreSQL credentials used to initialise the database and by the StatefulSet env.
  postgres-user: {{ postgres_user | b64encode }}
  postgres-password: {{ postgres_password | b64encode }}
  postgres-db: {{ postgres_db | b64encode }}
{% if postgres_use_tls %}
  # TLS private key used to authenticate this PostgreSQL server during the TLS handshake.
  tls-server.key: {{ lookup('file', postgres_k8s_tls_server_key_path) | b64encode }}
  # TLS server certificate presented to connecting clients.
  tls-server.crt: {{ lookup('file', postgres_k8s_tls_server_cert_path) | b64encode }}
  # TLS CA certificate used to verify incoming TLS connections.
  tls-ca.crt: {{ lookup('file', postgres_k8s_tls_ca_cert_path) | b64encode }}
{% endif %}
