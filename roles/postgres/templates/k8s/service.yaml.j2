---
apiVersion: v1
kind: Service
metadata:
  # Headless Service — required by the StatefulSet for stable DNS-based pod addressing.
  name: {{ postgres_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ postgres_k8s_resource_name }}
    app.kubernetes.io/part-of: {{ postgres_k8s_part_of }}
spec:
  # clusterIP: None makes this a headless Service — no virtual IP is assigned,
  # DNS resolves directly to the pod IP, which is needed by the StatefulSet.
  clusterIP: None
  selector:
    app.kubernetes.io/name: {{ postgres_k8s_resource_name }}
  ports:
    # PostgreSQL connection port.
    - name: postgres
      port: {{ postgres_port }}
      targetPort: {{ postgres_port }}
