---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  # One StatefulSet per PostgreSQL instance.
  name: {{ postgres_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ postgres_k8s_resource_name }}
    app.kubernetes.io/part-of: postgres
spec:
  # Must match the headless Service name so DNS-based pod addressing works.
  serviceName: {{ postgres_k8s_resource_name }}
  # One replica per PostgreSQL instance — scaling is done by adding nodes to
  # the Fabric network, not by scaling this pod.
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ postgres_k8s_resource_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ postgres_k8s_resource_name }}
        app.kubernetes.io/part-of: postgres
    spec:
      securityContext:
        # Ensures files mounted from Secrets and ConfigMaps are readable by
        # the postgres process running as a non-root user inside the container.
        fsGroup: {{ postgres_k8s_fs_group }}
      containers:
        - name: postgres
          image: {{ postgres_image }}
          imagePullPolicy: {{ k8s_image_pull_policy }}
          args:
            - postgres
            - -c
            - port={{ postgres_port }}
{% if postgres_use_tls %}
            - -c
            - ssl=on
            - -c
            - ssl_key_file={{ postgres_container_config_dir }}/tls/{{ postgres_tls_private_key_file }}
            - -c
            - ssl_cert_file={{ postgres_container_config_dir }}/tls/{{ postgres_tls_cert_file }}
{% endif %}
{% if postgres_mtls_clients is defined and postgres_mtls_clients | length > 0 %}
            - -c
            - hba_file={{ postgres_container_config_dir }}/pg_hba.conf
            - -c
            - ssl_ca_file={{ postgres_container_config_dir }}/mtls/ca-certs.pem
{% endif %}
{% if postgres_extra_cmd_opts is defined %}
            - "{{ postgres_extra_cmd_opts }}"
{% endif %}
          ports:
            - name: postgres
              # PostgreSQL connection port.
              containerPort: {{ postgres_port }}
              protocol: TCP
          env:
            - name: POSTGRES_USER
              valueFrom:
                secretKeyRef:
                  name: {{ postgres_k8s_resource_name }}-secret
                  key: postgres-user
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ postgres_k8s_resource_name }}-secret
                  key: postgres-password
            - name: POSTGRES_DB
              valueFrom:
                secretKeyRef:
                  name: {{ postgres_k8s_resource_name }}-secret
                  key: postgres-db
            - name: PGDATA
              value: {{ postgres_container_data_dir }}/pgdata
          readinessProbe:
            # pg_isready checks that PostgreSQL is accepting connections on the
            # configured port before the pod is marked ready and receives traffic.
            exec:
              command:
                - pg_isready
                - -U
                - {{ postgres_user }}
                - -d
                - {{ postgres_db }}
                - -p
                - "{{ postgres_port }}"
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
            successThreshold: 1
          livenessProbe:
            # pg_isready checks that the PostgreSQL process is alive. A simpler
            # check than readiness — no DB argument — so it fires only when the
            # process has completely stopped responding.
            exec:
              command:
                - pg_isready
                - -U
                - {{ postgres_user }}
                - -p
                - "{{ postgres_port }}"
            initialDelaySeconds: 30
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 5
            successThreshold: 1
          volumeMounts:
{% if postgres_use_tls %}
            # TLS private key for this PostgreSQL server.
            - name: secret
              mountPath: {{ postgres_container_config_dir }}/tls/{{ postgres_tls_private_key_file }}
              subPath: tls-server.key
              readOnly: true
            # TLS server certificate presented to connecting clients.
            - name: secret
              mountPath: {{ postgres_container_config_dir }}/tls/{{ postgres_tls_cert_file }}
              subPath: tls-server.crt
              readOnly: true
            # TLS CA certificate used to verify incoming TLS connections.
            - name: secret
              mountPath: {{ postgres_container_config_dir }}/tls/ca.crt
              subPath: tls-ca.crt
              readOnly: true
{% endif %}
{% if postgres_use_mtls and (postgres_mtls_clients is defined) and (postgres_mtls_clients | length > 0) %}
            # pg_hba.conf enforcing mTLS client certificate authentication.
            - name: config
              mountPath: {{ postgres_container_config_dir }}/pg_hba.conf
              subPath: pg_hba.conf
            # Assembled mTLS client CA bundle.
            - name: config
              mountPath: {{ postgres_container_config_dir }}/mtls/ca-certs.pem
              subPath: pg-mtls-ca-bundle.pem
{% endif %}
            # Persistent volume for PostgreSQL data.
            - name: data
              mountPath: {{ postgres_container_data_dir }}
      volumes:
{% if postgres_use_tls %}
        - name: secret
          # Secret holds sensitive TLS crypto material and credentials.
          secret:
            secretName: {{ postgres_k8s_resource_name }}-secret
            defaultMode: 0640
{% endif %}
{% if postgres_use_mtls and postgres_mtls_clients is defined and postgres_mtls_clients | length > 0 %}
        - name: config
          # ConfigMap holds pg_hba.conf and the mTLS client CA bundle.
          configMap:
            name: {{ postgres_k8s_resource_name }}-config
            defaultMode: 0640
{% endif %}
{% if k8s_image_pull_secret is defined and k8s_image_pull_secret %}
      imagePullSecrets:
        # Secret used to pull the postgres image from a private registry.
        - name: {{ k8s_image_pull_secret }}
{% endif %}
  volumeClaimTemplates:
    # PVC name — Kubernetes appends the pod ordinal (e.g. data-<name>-0).
    - metadata:
        name: data
      spec:
        accessModes:
          # Each PostgreSQL pod owns its own volume; no sharing between replicas.
          - ReadWriteOnce
{% if k8s_storage_class is defined and k8s_storage_class %}
        storageClassName: {{ k8s_storage_class }}
{% endif %}
        resources:
          requests:
            storage: {{ k8s_storage_size }}
