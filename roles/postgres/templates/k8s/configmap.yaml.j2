---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ postgres_k8s_resource_name }}-config
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ postgres_k8s_resource_name }}
    app.kubernetes.io/part-of: postgres
data:
{% if postgres_use_mtls and (postgres_mtls_clients is defined) and (postgres_mtls_clients | length > 0) %}
  # pg_hba.conf: enforces mTLS client certificate authentication.
  pg_hba.conf: |
    {{ lookup('file', postgres_k8s_pg_hba_path) | indent(4) }}
  # Assembled PEM bundle of all mTLS client CA certificates.
  pg-mtls-ca-bundle.pem: |
    {{ lookup('file', postgres_k8s_mtls_ca_bundle_path) | indent(4) }}
{% endif %}
