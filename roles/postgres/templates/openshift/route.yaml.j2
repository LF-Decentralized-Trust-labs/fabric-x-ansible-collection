---
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  # OpenShift Route — exposes PostgreSQL externally via a named host.
  # The Route targets the headless Service so external clients can reach
  # the PostgreSQL pod through a stable hostname instead of a NodePort.
  name: {{ postgres_k8s_resource_name }}-route
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ postgres_k8s_resource_name }}
    app.kubernetes.io/part-of: postgres
spec:
{% if postgres_openshift_route is defined %}
  # Explicit hostname for the Route. When omitted, OpenShift generates one
  # automatically based on the router configuration.
  host: {{ postgres_openshift_route }}
{% endif %}
  port:
    # targetPort references the named port on the headless Service so the
    # Route forwards traffic to the correct container port regardless of
    # the numeric value configured in postgres_port.
    targetPort: postgres
  to:
    # Backend Service that receives traffic forwarded by the Route.
    kind: Service
    name: {{ postgres_k8s_resource_name }}
{% if postgres_use_tls %}
  # Passthrough TLS termination — the Route forwards encrypted traffic
  # directly to the pod without decrypting it. PostgreSQL handles TLS
  # termination using the certificates mounted from the Secret.
  tls:
    termination: passthrough
{% endif %}
