apiVersion: v1
kind: Service
metadata:
  name: "{{ alloy_k8s_resource_name }}"
  labels:
    app.kubernetes.io/name: "{{ alloy_k8s_resource_name }}"
    app.kubernetes.io/component: alloy
    app.kubernetes.io/part-of: "{{ alloy_k8s_part_of }}"
spec:
  selector:
    app.kubernetes.io/name: "{{ alloy_k8s_resource_name }}"
  ports:
    - name: http
      port: "{{ alloy_http_port }}"
      targetPort: "{{ alloy_http_port }}"
      protocol: TCP
