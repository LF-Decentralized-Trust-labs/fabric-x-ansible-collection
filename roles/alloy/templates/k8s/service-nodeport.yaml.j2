---
apiVersion: v1
kind: Service
metadata:
  name: {{ alloy_k8s_resource_name }}-nodeport
  labels:
    app.kubernetes.io/name: {{ alloy_k8s_resource_name }}
    app.kubernetes.io/component: alloy
    app.kubernetes.io/part-of: {{ alloy_k8s_part_of }}
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: {{ alloy_k8s_resource_name }}
  ports:
{% if alloy_k8s_node_port is defined %}
    - name: http
      port: {{ alloy_port }}
      targetPort: http
      nodePort: {{ alloy_k8s_node_port }}
      protocol: TCP
{% endif %}
