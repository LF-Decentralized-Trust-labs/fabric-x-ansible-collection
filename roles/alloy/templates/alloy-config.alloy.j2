// Grafana Alloy configuration — generated by Ansible (hyperledger.fabricx.alloy)
// Do not edit manually; re-run the configs playbook to regenerate.
// River syntax: https://grafana.com/docs/alloy/latest/concepts/configuration-syntax/

// -------------------------------------------------------------------------
// Logging (Alloy's own internal log level)
// -------------------------------------------------------------------------
logging {
  level  = "info"
  format = "logfmt"
}

{% if alloy_use_k8s or alloy_use_openshift %}
// -------------------------------------------------------------------------
// Kubernetes pod log discovery
// -------------------------------------------------------------------------
discovery.kubernetes "pods" {
  role = "pod"
{% if alloy_k8s_namespaces is defined and alloy_k8s_namespaces | length > 0 %}

  namespaces {
    names = [
{% for namespace in alloy_k8s_namespaces %}
      "{{ namespace }}",
{% endfor %}
    ]
  }
{% endif %}
}

discovery.relabel "pod_labels" {
  targets = discovery.kubernetes.pods.targets

{% if alloy_k8s_keep_part_of_regex is defined and alloy_k8s_keep_part_of_regex | length > 0 %}
  rule {
    source_labels = ["__meta_kubernetes_pod_label_app_kubernetes_io_part_of"]
    regex         = "{{ alloy_k8s_keep_part_of_regex }}"
    action        = "keep"
  }

{% endif %}
  rule {
    source_labels = ["__meta_kubernetes_namespace"]
    target_label  = "namespace"
  }

  rule {
    source_labels = ["__meta_kubernetes_pod_name"]
    target_label  = "pod"
  }

  rule {
    source_labels = ["__meta_kubernetes_pod_container_name"]
    target_label  = "container"
  }

  rule {
    source_labels = ["__meta_kubernetes_pod_label_app"]
    target_label  = "app"
  }

  rule {
    source_labels = ["__meta_kubernetes_pod_label_app_kubernetes_io_name"]
    target_label  = "service_name"
  }

  rule {
    source_labels = ["__meta_kubernetes_pod_name"]
    regex         = "onb-repo-webserver.*"
    target_label  = "service"
    replacement   = "onboarding-repository"
  }
}

loki.source.kubernetes "pod_logs" {
  targets    = discovery.relabel.pod_labels.output
  forward_to = [loki.process.json_pipeline.receiver]
}

{% else %}
// -------------------------------------------------------------------------
// Docker container log discovery
// -------------------------------------------------------------------------
{% if alloy_docker_logs_enabled %}
discovery.docker "containers" {
  host = "{{ alloy_docker_host }}"
}

discovery.relabel "docker_labels" {
  targets = discovery.docker.containers.targets

{% if alloy_docker_exclude_container_regex | length > 0 %}
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "{{ alloy_docker_exclude_container_regex }}"
    action        = "drop"
  }

{% endif %}
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "app"
  }

  rule {
    source_labels = ["__meta_docker_container_image"]
    target_label  = "image"
  }

  // Apply service label only to onb-repo-webserver container
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/onb-repo-webserver"
    target_label  = "service"
    replacement   = "onboarding-repository"
  }
}

loki.source.docker "docker_logs" {
  host       = "{{ alloy_docker_host }}"
  targets    = discovery.relabel.docker_labels.output
  forward_to = [loki.process.json_pipeline.receiver]
}
{% endif %}

{% if alloy_journal_logs_enabled %}
// -------------------------------------------------------------------------
// Systemd journal log discovery
// -------------------------------------------------------------------------
loki.source.journal "journal_logs" {
  max_age       = "12h"
  forward_to    = [loki.process.json_pipeline.receiver]
  labels        = {
    job = "systemd-journal",
{% for k, v in alloy_default_labels.items() %}
    {{ k }} = "{{ v }}",
{% endfor %}
  }
}
{% endif %}

{% if alloy_extra_log_paths | length > 0 %}
// -------------------------------------------------------------------------
// File-based log discovery (extra paths)
// -------------------------------------------------------------------------
local.file_match "extra_files" {
  path_targets = [
{% for path in alloy_extra_log_paths %}
    { "__path__" = "{{ path }}" },
{% endfor %}
  ]
}

loki.source.file "extra_logs" {
  targets    = local.file_match.extra_files.targets
  forward_to = [loki.process.json_pipeline.receiver]
}
{% endif %}
{% endif %}

// -------------------------------------------------------------------------
// JSON parsing pipeline
// Extracts structured fields from JSON log lines and promotes
// selected fields as Loki labels. High-cardinality fields (e.g. txn_id,
// duration_ms) are intentionally NOT promoted to labels — they remain
// queryable via LogQL `| json` + field filters.
// -------------------------------------------------------------------------
loki.process "json_pipeline" {
  forward_to = [loki.write.loki_endpoint.receiver]

{% if alloy_use_k8s or alloy_use_openshift %}
  stage.json {
    expressions = {
{% for field in alloy_json_label_fields %}
      {{ field }} = "{{ field }}",
{% endfor %}
      timestamp = "timestamp",
    }
  }

  stage.labels {
    values = {
{% for field in alloy_json_label_fields %}
      {{ field }} = "",
{% endfor %}
    }
  }

  stage.static_labels {
    values = {
{% for k, v in alloy_default_labels.items() %}
      {{ k }} = "{{ v }}",
{% endfor %}
    }
  }

  stage.timestamp {
    source = "timestamp"
    format = "RFC3339"
    fallback_formats = ["RFC3339Nano", "UnixMs"]
    action_on_failure = "skip"
  }
{% else %}
{% if alloy_json_label_fields | length > 0 %}
  // Attempt JSON parsing; non-JSON lines pass through unchanged
  stage.json {
    expressions = {
{% for field in alloy_json_label_fields %}
      {{ field }} = "{{ field }}",
{% endfor %}
    }
  }

  // Promote the extracted fields to labels
  stage.labels {
    values = {
{% for field in alloy_json_label_fields %}
      {{ field }} = "",
{% endfor %}
    }
  }

{% endif %}
  // Attach static platform labels to every log entry
  stage.static_labels {
    values = {
{% for k, v in alloy_default_labels.items() %}
      {{ k }} = "{{ v }}",
{% endfor %}
    }
  }
{% endif %}
}

// -------------------------------------------------------------------------
// Loki write endpoint
// -------------------------------------------------------------------------
loki.write "loki_endpoint" {
  endpoint {
    url = "{{ alloy_loki_url }}"
  }
  external_labels = {
{% for k, v in alloy_default_labels.items() %}
    {{ k }} = "{{ v }}",
{% endfor %}
  }
}
