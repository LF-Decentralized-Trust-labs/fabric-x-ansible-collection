// -------------------------------------------------------------------------
// File-based log discovery (extra paths)
// -------------------------------------------------------------------------

// Expands configured file globs into file targets for Alloy to tail.
local.file_match "extra_files" {
  path_targets = [
{% for path in alloy_extra_log_paths %}
    { "__path__" = "{{ path }}" },
{% endfor %}
  ]
}

// Tails additional matched files and forwards their log entries to Loki.
loki.source.file "extra_logs" {
  targets    = local.file_match.extra_files.targets
  forward_to = [loki.write.loki_endpoint.receiver]
}
