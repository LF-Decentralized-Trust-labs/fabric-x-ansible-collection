// -------------------------------------------------------------------------
// Kubernetes pod log discovery
// -------------------------------------------------------------------------

// Discovers Kubernetes pods whose container logs Alloy can collect.
discovery.kubernetes "pods" {
  role = "pod"
{% if alloy_k8s_namespaces is defined and alloy_k8s_namespaces | length > 0 %}
  namespaces {
    names = [
{% for namespace in alloy_k8s_namespaces %}
      "{{ namespace }}",
{% endfor %}
    ]
  }
{% endif %}
}

// Rewrites Kubernetes discovery metadata into stable Loki labels.
discovery.relabel "pod_labels" {
  targets = discovery.kubernetes.pods.targets
  // Copy the Kubernetes namespace into a Loki label.
  // Example output: namespace="default".
  rule {
    source_labels = ["__meta_kubernetes_namespace"]
    target_label  = "namespace"
  }

  // Copy the Kubernetes pod name into a Loki label.
  // Example output: pod="orderer-0".
  rule {
    source_labels = ["__meta_kubernetes_pod_name"]
    target_label  = "pod"
  }

  // Copy the container name inside the pod into a Loki label.
  // Example output: container="orderer".
  rule {
    source_labels = ["__meta_kubernetes_pod_container_name"]
    target_label  = "container"
  }

  // Copy the legacy app label when workloads define it.
  // Example output: app="committer".
  rule {
    source_labels = ["__meta_kubernetes_pod_label_app"]
    target_label  = "app"
  }

  // Copy app.kubernetes.io/name directly to Loki's service name label.
  // Example output: service_name="committer".
  rule {
    source_labels = ["__meta_kubernetes_pod_label_app_kubernetes_io_name"]
    target_label  = "service_name"
  }

  // Emit one boolean label per inventory group the pod belongs to, so logs can be
  // filtered by topology, e.g. {fabric_x_orderers="true"}. One rule per group; the regex
  // matches the app.kubernetes.io/name label (= inventory hostname) of that group's members.
{% for group_name in groups | sort %}
{% if groups[group_name] | length > 0 %}
  rule {
    source_labels = ["__meta_kubernetes_pod_label_app_kubernetes_io_name"]
    regex         = "({{ groups[group_name] | sort | join('|') }})"
    target_label  = "{{ group_name }}"
    replacement   = "group"
    action        = "replace"
  }
{% endif %}
{% endfor %}
}

// Reads pod logs from the Kubernetes API and forwards them to Loki.
loki.source.kubernetes "pod_logs" {
  targets    = discovery.relabel.pod_labels.output
  forward_to = [loki.write.loki_endpoint.receiver]
}
