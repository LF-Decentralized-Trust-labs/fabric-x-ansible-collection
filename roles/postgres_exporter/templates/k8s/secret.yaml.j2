---
apiVersion: v1
kind: Secret
metadata:
  name: {{ postgres_exporter_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ postgres_exporter_k8s_resource_name }}
    app.kubernetes.io/component: postgres-exporter
    app.kubernetes.io/part-of: monitoring
type: Opaque
data:
  DATA_SOURCE_NAME: {{ postgres_exporter_data_source_name | b64encode }}
{% if postgres_exporter_use_tls %}
  {{ postgres_exporter_tls_private_key_file }}: {{ lookup('file', postgres_exporter_k8s_tls_key_path) | b64encode }}
  {{ postgres_exporter_tls_cert_file }}: {{ lookup('file', postgres_exporter_k8s_tls_cert_path) | b64encode }}
{% endif %}
