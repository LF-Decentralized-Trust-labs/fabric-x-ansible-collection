---
apiVersion: v1
kind: Service
metadata:
  # LoadBalancer Service -- exposes Postgres Exporter outside the cluster for external clients.
  name: {{ postgres_exporter_k8s_resource_name }}-loadbalancer
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ postgres_exporter_k8s_resource_name }}
    app.kubernetes.io/component: postgres-exporter
    app.kubernetes.io/part-of: monitoring
spec:
  type: LoadBalancer
  selector:
    app.kubernetes.io/name: {{ postgres_exporter_k8s_resource_name }}
  ports:
{% if postgres_exporter_k8s_loadbalancer_expose_metrics_port %}
    - name: metrics
      port: {{ postgres_exporter_port }}
      targetPort: metrics
{% endif %}
