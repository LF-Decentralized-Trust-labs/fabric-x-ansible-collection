---
apiVersion: v1
kind: Service
metadata:
  name: {{ postgres_exporter_k8s_resource_name }}-nodeport
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ postgres_exporter_k8s_resource_name }}
    app.kubernetes.io/component: postgres-exporter
    app.kubernetes.io/part-of: monitoring
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: {{ postgres_exporter_k8s_resource_name }}
  ports:
{% if postgres_exporter_k8s_port_node_port is defined %}
    - name: metrics
      port: {{ postgres_exporter_port }}
      targetPort: {{ postgres_exporter_port }}
      nodePort: {{ postgres_exporter_k8s_port_node_port }}
{% endif %}
