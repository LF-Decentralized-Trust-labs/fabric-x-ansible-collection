---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ postgres_exporter_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ postgres_exporter_k8s_resource_name }}
    app.kubernetes.io/component: postgres-exporter
    app.kubernetes.io/part-of: {{ postgres_exporter_k8s_part_of }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ postgres_exporter_k8s_resource_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ postgres_exporter_k8s_resource_name }}
        app.kubernetes.io/component: postgres-exporter
        app.kubernetes.io/part-of: {{ postgres_exporter_k8s_part_of }}
    spec:
      securityContext:
        fsGroup: {{ postgres_exporter_k8s_fs_group }}
      containers:
        - name: postgres-exporter
          image: {{ postgres_exporter_image }}
          args:
            - --web.listen-address=:{{ postgres_exporter_port }}
            - --config.file={{ postgres_exporter_container_config_dir }}/{{ postgres_exporter_config_file }}
{% if postgres_exporter_use_tls %}
            - --web.config.file={{ postgres_exporter_container_config_dir }}/{{ postgres_exporter_web_config_file }}
{% endif %}
          env:
            - name: DATA_SOURCE_NAME
              valueFrom:
                secretKeyRef:
                  name: {{ postgres_exporter_k8s_resource_name }}
                  key: DATA_SOURCE_NAME
          ports:
            - name: metrics
              containerPort: {{ postgres_exporter_port }}
              protocol: TCP
          volumeMounts:
            - name: config
              mountPath: {{ postgres_exporter_container_config_dir }}/{{ postgres_exporter_config_file }}
              subPath: {{ postgres_exporter_config_file }}
              readOnly: true
{% if postgres_exporter_use_tls %}
            - name: config
              mountPath: {{ postgres_exporter_container_config_dir }}/{{ postgres_exporter_web_config_file }}
              subPath: {{ postgres_exporter_web_config_file }}
              readOnly: true
            - name: secret
              mountPath: {{ postgres_exporter_container_config_dir }}/tls/{{ postgres_exporter_tls_cert_file }}
              subPath: {{ postgres_exporter_tls_cert_file }}
              readOnly: true
            - name: secret
              mountPath: {{ postgres_exporter_container_config_dir }}/tls/{{ postgres_exporter_tls_private_key_file }}
              subPath: {{ postgres_exporter_tls_private_key_file }}
              readOnly: true
{% endif %}
{% if hostvars[postgres_db_host].postgres_use_tls is defined and hostvars[postgres_db_host].postgres_use_tls %}
            - name: config
              mountPath: {{ postgres_exporter_container_config_dir }}/tls/db-ca.crt
              subPath: db-ca.crt
              readOnly: true
{% endif %}
          readinessProbe:
            tcpSocket:
              port: {{ postgres_exporter_port }}
            initialDelaySeconds: {{ k8s_readiness_probe_initial_delay_seconds | default(10) }}
            periodSeconds: {{ k8s_readiness_probe_period_seconds | default(10) }}
            timeoutSeconds: {{ k8s_readiness_probe_timeout_seconds | default(5) }}
            failureThreshold: {{ k8s_readiness_probe_failure_threshold | default(3) }}
            successThreshold: 1
          livenessProbe:
            tcpSocket:
              port: {{ postgres_exporter_port }}
            initialDelaySeconds: {{ k8s_liveness_probe_initial_delay_seconds | default(30) }}
            periodSeconds: {{ k8s_liveness_probe_period_seconds | default(15) }}
            timeoutSeconds: {{ k8s_liveness_probe_timeout_seconds | default(5) }}
            failureThreshold: {{ k8s_liveness_probe_failure_threshold | default(5) }}
            successThreshold: 1
      volumes:
        - name: config
          configMap:
            name: {{ postgres_exporter_k8s_resource_name }}
            defaultMode: 0640
        - name: secret
          secret:
            secretName: {{ postgres_exporter_k8s_resource_name }}
            defaultMode: 0640
{% if k8s_image_pull_secret is defined and k8s_image_pull_secret %}
      imagePullSecrets:
        - name: {{ k8s_image_pull_secret }}
{% endif %}
