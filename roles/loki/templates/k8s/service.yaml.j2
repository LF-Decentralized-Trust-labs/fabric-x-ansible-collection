---
apiVersion: v1
kind: Service
metadata:
  # Headless Service required by the StatefulSet for stable DNS-based pod addressing.
  name: {{ loki_k8s_resource_name }}
  labels:
    app.kubernetes.io/name: {{ loki_k8s_resource_name }}
    app.kubernetes.io/component: loki
    app.kubernetes.io/part-of: {{ loki_k8s_part_of }}
spec:
  clusterIP: None
  publishNotReadyAddresses: true
  selector:
    app.kubernetes.io/name: {{ loki_k8s_resource_name }}
  ports:
    - name: http
      port: {{ loki_port }}
      targetPort: http
      protocol: TCP
    - name: grpc
      port: {{ loki_grpc_port }}
      targetPort: grpc
      protocol: TCP
