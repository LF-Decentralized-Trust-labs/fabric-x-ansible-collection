---
apiVersion: v1
kind: Service
metadata:
  # LoadBalancer Service -- exposes Grafana outside the cluster for external clients.
  name: {{ grafana_k8s_resource_name }}-loadbalancer
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ grafana_k8s_resource_name }}
    app.kubernetes.io/component: grafana
    app.kubernetes.io/part-of: monitoring
spec:
  type: LoadBalancer
  selector:
    app.kubernetes.io/name: {{ grafana_k8s_resource_name }}
  ports:
{% if grafana_k8s_loadbalancer_expose_web_port %}
    - name: web
      port: {{ grafana_web_port }}
      targetPort: web
{% endif %}
