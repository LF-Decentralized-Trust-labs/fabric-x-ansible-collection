---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ grafana_k8s_resource_name }}
  labels:
    app.kubernetes.io/name: {{ grafana_k8s_resource_name }}
    app.kubernetes.io/component: grafana
    app.kubernetes.io/part-of: {{ grafana_k8s_part_of }}
data:
  datasources.yaml: |
{{ lookup('file', grafana_k8s_datasources_path) | indent(4, true) }}
  dashboards.yaml: |
{{ lookup('file', grafana_k8s_dashboards_path) | indent(4, true) }}
{% if hostvars[prometheus_host].prometheus_use_tls is defined and hostvars[prometheus_host].prometheus_use_tls %}
  prometheus-ca.crt: |
{{ lookup('file', grafana_k8s_prometheus_ca_path) | indent(4, true) }}
{% endif %}
{% if loki_host is defined and hostvars[loki_host].loki_use_tls is defined and hostvars[loki_host].loki_use_tls %}
  loki-ca.crt: |
{{ lookup('file', grafana_k8s_loki_ca_path) | indent(4, true) }}
{% endif %}
