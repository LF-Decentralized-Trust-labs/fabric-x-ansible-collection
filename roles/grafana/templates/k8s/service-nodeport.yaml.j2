---
apiVersion: v1
kind: Service
metadata:
  name: {{ grafana_k8s_resource_name }}-nodeport
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ grafana_k8s_resource_name }}
    app.kubernetes.io/component: grafana
    app.kubernetes.io/part-of: monitoring
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: {{ grafana_k8s_resource_name }}
  ports:
{% if grafana_k8s_web_node_port is defined %}
    - name: web
      port: {{ grafana_web_port }}
      targetPort: {{ grafana_web_port }}
      nodePort: {{ grafana_k8s_web_node_port }}
{% endif %}
