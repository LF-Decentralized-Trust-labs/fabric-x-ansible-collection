---
apiVersion: v1
kind: Service
metadata:
  name: {{ loadgen_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ loadgen_k8s_resource_name }}
    app.kubernetes.io/component: loadgen
    app.kubernetes.io/part-of: fabric-x-loadgen
spec:
  selector:
    app.kubernetes.io/name: {{ loadgen_k8s_resource_name }}
  ports:
    # HTTP API port used for rate-limit control and health checks.
    - name: web
      port: {{ loadgen_web_port }}
      targetPort: {{ loadgen_web_port }}
    # Prometheus metrics scrape endpoint.
    - name: metrics
      port: {{ loadgen_metrics_port }}
      targetPort: {{ loadgen_metrics_port }}
    # gRPC API port for programmatic control of load generation.
    - name: rpc
      port: {{ loadgen_rpc_port }}
      targetPort: {{ loadgen_rpc_port }}
