---
apiVersion: v1
kind: Service
metadata:
  # LoadBalancer Service -- exposes Fabric-X Loadgen outside the cluster for external clients.
  name: {{ loadgen_k8s_resource_name }}-loadbalancer
  labels:
    app.kubernetes.io/name: {{ loadgen_k8s_resource_name }}
    app.kubernetes.io/component: loadgen
    app.kubernetes.io/part-of: {{ loadgen_k8s_part_of }}
spec:
  type: LoadBalancer
  selector:
    app.kubernetes.io/name: {{ loadgen_k8s_resource_name }}
  ports:
{% if loadgen_k8s_loadbalancer_expose_metrics_port %}
    - name: metrics
      port: {{ loadgen_metrics_port }}
      targetPort: metrics
{% endif %}
{% if loadgen_k8s_loadbalancer_expose_rpc_port %}
    - name: rpc
      port: {{ loadgen_rpc_port }}
      targetPort: rpc
{% endif %}
