---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ loadgen_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ loadgen_k8s_resource_name }}
    app.kubernetes.io/component: {{ loadgen_type }}
    app.kubernetes.io/part-of: fabric-x-loadgen
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ loadgen_k8s_resource_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ loadgen_k8s_resource_name }}
        app.kubernetes.io/component: {{ loadgen_type }}
        app.kubernetes.io/part-of: fabric-x-loadgen
    spec:
      securityContext:
        fsGroup: {{ loadgen_k8s_fs_group }}
      containers:
        - name: loadgen
          image: {{ loadgen_image }}
          args:
            - "start"
            - "--config={{ loadgen_container_config_dir }}/{{ loadgen_config_file }}"
          ports:
            - name: web
              containerPort: {{ loadgen_web_port }}
              protocol: TCP
            - name: metrics
              containerPort: {{ loadgen_metrics_port }}
              protocol: TCP
            - name: rpc
              containerPort: {{ loadgen_rpc_port }}
              protocol: TCP
          volumeMounts:
            # Main loadgen configuration file.
            - name: config
              mountPath: {{ loadgen_container_config_dir }}/{{ loadgen_config_file }}
              subPath: config-loadgen.yaml
{% if organization.users is defined %}
{% for user in organization.users %}
{% if user.namespace is defined %}
            # MSP private signing key for user {{ user.name }}.
            - name: secret
              mountPath: {{ loadgen_container_config_dir }}/users/{{ user.name }}@{{ organization.domain }}/msp/keystore/priv_sk
              subPath: user-{{ user.name }}-msp-keystore-priv-sk
              readOnly: true
{% if organization.fabric_ca_host is defined %}
            # MSP signing certificate for user {{ user.name }} (Fabric CA).
            - name: secret
              mountPath: {{ loadgen_container_config_dir }}/users/{{ user.name }}@{{ organization.domain }}/msp/signcerts/cert.pem
              subPath: user-{{ user.name }}-msp-signcert.pem
              readOnly: true
{% else %}
            # MSP signing certificate for user {{ user.name }} (cryptogen).
            - name: secret
              mountPath: {{ loadgen_container_config_dir }}/users/{{ user.name }}@{{ organization.domain }}/msp/signcerts/{{ user.name }}@{{ organization.domain }}-cert.pem
              subPath: user-{{ user.name }}-msp-signcert.pem
              readOnly: true
{% endif %}
            # MSP CA certificate for user {{ user.name }}.
            - name: secret
              mountPath: {{ loadgen_container_config_dir }}/users/{{ user.name }}@{{ organization.domain }}/msp/cacerts/ca.{{ organization.domain }}-cert.pem
              subPath: user-{{ user.name }}-msp-cacert.pem
              readOnly: true
{% endif %}
{% endfor %}
{% endif %}
{% if loadgen_use_tls or loadgen_monitoring_use_tls %}
            # TLS private key.
            - name: secret
              mountPath: {{ loadgen_container_config_dir }}/tls/server.key
              subPath: tls-server.key
              readOnly: true
            # TLS server certificate.
            - name: secret
              mountPath: {{ loadgen_container_config_dir }}/tls/server.crt
              subPath: tls-server.crt
              readOnly: true
            # TLS CA certificate.
            - name: secret
              mountPath: {{ loadgen_container_config_dir }}/tls/ca.crt
              subPath: tls-ca.crt
              readOnly: true
{% endif %}
{% if loadgen_use_mtls and loadgen_mtls_clients is defined %}
{% for current_loadgen_mtls_client in loadgen_mtls_clients %}
            # mTLS CA certificate for client {{ current_loadgen_mtls_client }} (gRPC server).
            - name: config
              mountPath: {{ loadgen_container_config_dir }}/mtls/{{ current_loadgen_mtls_client }}/ca.crt
              subPath: mtls-client-{{ current_loadgen_mtls_client }}-ca.crt
              readOnly: true
{% endfor %}
{% endif %}
{% if loadgen_use_mtls and loadgen_mtls_orgs is defined %}
{% for current_loadgen_mtls_org in loadgen_mtls_orgs %}
            # mTLS CA certificate for org {{ current_loadgen_mtls_org.domain }} (gRPC server).
            - name: config
              mountPath: {{ loadgen_container_config_dir }}/mtls/{{ current_loadgen_mtls_org.domain }}/ca.crt
              subPath: mtls-org-{{ current_loadgen_mtls_org.domain }}-ca.crt
              readOnly: true
{% endfor %}
{% endif %}
{% if loadgen_monitoring_use_mtls and loadgen_monitoring_mtls_clients is defined %}
{% for current_loadgen_monitoring_mtls_client in loadgen_monitoring_mtls_clients %}
{% if current_loadgen_monitoring_mtls_client not in (loadgen_mtls_clients | default([])) %}
            # mTLS CA certificate for client {{ current_loadgen_monitoring_mtls_client }} (monitoring).
            - name: config
              mountPath: {{ loadgen_container_config_dir }}/mtls/{{ current_loadgen_monitoring_mtls_client }}/ca.crt
              subPath: mtls-client-{{ current_loadgen_monitoring_mtls_client }}-ca.crt
              readOnly: true
{% endif %}
{% endfor %}
{% endif %}
{% if loadgen_monitoring_use_mtls and loadgen_monitoring_mtls_orgs is defined %}
{% for current_loadgen_monitoring_mtls_org in loadgen_monitoring_mtls_orgs %}
{% if current_loadgen_monitoring_mtls_org not in (loadgen_mtls_orgs | default([])) %}
            # mTLS CA certificate for org {{ current_loadgen_monitoring_mtls_org.domain }} (monitoring).
            - name: config
              mountPath: {{ loadgen_container_config_dir }}/mtls/{{ current_loadgen_monitoring_mtls_org.domain }}/ca.crt
              subPath: mtls-org-{{ current_loadgen_monitoring_mtls_org.domain }}-ca.crt
              readOnly: true
{% endif %}
{% endfor %}
{% endif %}
{% if (hostvars[committer_validator_ref_host].committer_use_tls is defined) and hostvars[committer_validator_ref_host].committer_use_tls %}
            # TLS CA certificate of the validators (upstream servers).
            - name: config
              mountPath: {{ loadgen_container_config_dir }}/tls/validators/ca.crt
              subPath: tls-validators-ca.crt
              readOnly: true
{% endif %}
      volumes:
        - name: config
          configMap:
            name: {{ loadgen_k8s_resource_name }}-config
            defaultMode: 0640
{% if loadgen_use_tls or loadgen_monitoring_use_tls %}
        - name: secret
          secret:
            secretName: {{ loadgen_k8s_resource_name }}-secret
            defaultMode: 0640
{% endif %}
{% if k8s_image_pull_secret is defined and k8s_image_pull_secret %}
      imagePullSecrets:
        - name: {{ k8s_image_pull_secret }}
{% endif %}
