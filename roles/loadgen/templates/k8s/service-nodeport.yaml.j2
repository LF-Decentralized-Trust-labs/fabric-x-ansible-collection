---
apiVersion: v1
kind: Service
metadata:
  name: {{ loadgen_k8s_resource_name }}-nodeport
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ loadgen_k8s_resource_name }}
    app.kubernetes.io/component: {{ loadgen_type }}
    app.kubernetes.io/part-of: fabric-x-loadgen
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: {{ loadgen_k8s_resource_name }}
  ports:
    # HTTP API port exposed externally via NodePort.
    - name: web
      port: {{ loadgen_web_port }}
      targetPort: {{ loadgen_web_port }}
      nodePort: {{ loadgen_k8s_web_node_port }}
    # Prometheus metrics port exposed externally via NodePort.
    - name: metrics
      port: {{ loadgen_metrics_port }}
      targetPort: {{ loadgen_metrics_port }}
      nodePort: {{ loadgen_k8s_metrics_node_port }}
    # gRPC API port exposed externally via NodePort.
    - name: rpc
      port: {{ loadgen_rpc_port }}
      targetPort: {{ loadgen_rpc_port }}
      nodePort: {{ loadgen_k8s_rpc_node_port }}
