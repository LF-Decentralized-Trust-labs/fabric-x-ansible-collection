---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ loadgen_k8s_resource_name }}-config
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ loadgen_k8s_resource_name }}
    app.kubernetes.io/component: {{ loadgen_type }}
    app.kubernetes.io/part-of: fabric-x-loadgen
data:
  # Main loadgen configuration passed via --config at startup.
  config-loadgen.yaml: |
    {{ lookup('file', loadgen_remote_config_dir + '/' + loadgen_config_file) | indent(4) }}
{% if (hostvars[committer_coordinator_host].committer_use_tls is defined) and hostvars[committer_coordinator_host].committer_use_tls %}
  # TLS CA certificate of the coordinator (used for upstream TLS verification).
  tls-coordinator-ca.crt: |
    {{ lookup('file', loadgen_remote_config_dir + '/tls/coordinator/ca.crt') | indent(4) }}
{% endif %}
{% if loadgen_use_mtls and loadgen_mtls_clients is defined %}
{% for current_loadgen_mtls_client in loadgen_mtls_clients %}
  # mTLS CA certificate for client {{ current_loadgen_mtls_client }} (accepted on gRPC server).
  mtls-client-{{ current_loadgen_mtls_client }}-ca.crt: |
    {{ lookup('file', loadgen_remote_config_dir + '/mtls/' + current_loadgen_mtls_client + '/ca.crt') | indent(4) }}
{% endfor %}
{% endif %}
{% if loadgen_use_mtls and loadgen_mtls_orgs is defined %}
{% for current_loadgen_mtls_org in loadgen_mtls_orgs %}
  # mTLS CA certificate for org {{ current_loadgen_mtls_org.domain }} (accepted on gRPC server).
  mtls-org-{{ current_loadgen_mtls_org.domain }}-ca.crt: |
    {{ lookup('file', loadgen_remote_config_dir + '/mtls/' + current_loadgen_mtls_org.domain + '/ca.crt') | indent(4) }}
{% endfor %}
{% endif %}
{% if loadgen_monitoring_use_mtls and loadgen_monitoring_mtls_clients is defined %}
{% for current_loadgen_monitoring_mtls_client in loadgen_monitoring_mtls_clients %}
{% if current_loadgen_monitoring_mtls_client not in (loadgen_mtls_clients | default([])) %}
  # mTLS CA certificate for client {{ current_loadgen_monitoring_mtls_client }} (accepted on monitoring endpoint).
  mtls-client-{{ current_loadgen_monitoring_mtls_client }}-ca.crt: |
    {{ lookup('file', loadgen_remote_config_dir + '/mtls/' + current_loadgen_monitoring_mtls_client + '/ca.crt') | indent(4) }}
{% endif %}
{% endfor %}
{% endif %}
{% if loadgen_monitoring_use_mtls and loadgen_monitoring_mtls_orgs is defined %}
{% for current_loadgen_monitoring_mtls_org in loadgen_monitoring_mtls_orgs %}
{% if current_loadgen_monitoring_mtls_org not in (loadgen_mtls_orgs | default([])) %}
  # mTLS CA certificate for org {{ current_loadgen_monitoring_mtls_org.domain }} (accepted on monitoring endpoint).
  mtls-org-{{ current_loadgen_monitoring_mtls_org.domain }}-ca.crt: |
    {{ lookup('file', loadgen_remote_config_dir + '/mtls/' + current_loadgen_monitoring_mtls_org.domain + '/ca.crt') | indent(4) }}
{% endif %}
{% endfor %}
{% endif %}
