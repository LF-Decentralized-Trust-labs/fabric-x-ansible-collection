# ---------------------------------------------------------------------------
# Generation phases settings
# If omitted, all phases will be generated by default.
# ---------------------------------------------------------------------------
generate:
  # Controls whether the loadgen generates a config transaction during the config phase.
  # When false, the config transaction is expected to be submitted outside the loadgen.
  # Ignored by the coordinator, VC, and verifier adapters.
  config: {{ loadgen_generate_config | default(false) | bool | lower }}
  # Controls whether to generate namespace creation transactions during the namespaces phase.
  # Required for new deployments to set up the namespace structure before generating regular load.
  namespaces: {{ loadgen_generate_namespace | default(false) | bool | lower }}
  # Controls whether to generate regular transaction load during the load phase.
  # Can be disabled if only namespace setup or config updates are needed.
  load: {{ loadgen_generate_load | default(true) | bool | lower }}
