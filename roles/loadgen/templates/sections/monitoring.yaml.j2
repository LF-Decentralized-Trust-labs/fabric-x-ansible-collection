# ---------------------------------------------------------------------------
# Monitoring settings
# ---------------------------------------------------------------------------
monitoring:
  # The endpoint where Prometheus metrics and pprof profiling are exposed.
  # Format: host:port or :port (binds to all interfaces).
  endpoint: 0.0.0.0:{{ loadgen_metrics_port }}
{% if loadgen_monitoring_use_tls %}
  # Define TLS options and certificate paths used for secure communication
  # between servers and clients. Credentials are built based on the configuration mode.
  # For example, If only server-side TLS is required, the certificate pool (certPool)
  # is not built (for a server), since the relevant certificates paths are defined
  # in the YAML according to the selected mode.
  tls:
    # Path to the server's TLS private key file.
    key-path: {{ loadgen_config_dir }}/tls/server.key
    # Path to the server's TLS certificate file (public key).
    cert-path: {{ loadgen_config_dir }}/tls/server.crt
{% if loadgen_monitoring_use_mtls %}
    # TLS mode for server connections: 'none' (no TLS), 'tls' (server auth only),
    # or 'mtls' (mutual TLS with client cert verification).
    mode: mtls
    # List of paths to CA certificate files for verifying client certificates (required for mtls).
    ca-cert-paths:
      # Accept mTLS connections from others within the same org
      - {{ loadgen_config_dir }}/tls/ca.crt
{% if loadgen_monitoring_mtls_clients is defined %}
      # Other mTLS clients
{% for loadgen_monitoring_mtls_client in loadgen_monitoring_mtls_clients %}
      - {{ loadgen_config_dir }}/mtls/{{ loadgen_monitoring_mtls_client }}/ca.crt
{% endfor %}
{% endif %}
{% if loadgen_monitoring_mtls_orgs is defined %}
      # Other mTLS Orgs
{% for loadgen_monitoring_mtls_org in loadgen_monitoring_mtls_orgs %}
      - {{ loadgen_config_dir }}/mtls/{{ loadgen_monitoring_mtls_org.domain }}/ca.crt
{% endfor %}
{% endif %}
{% else %}
    # TLS mode for server connections: 'none' (no TLS), 'tls' (server auth only),
    # or 'mtls' (mutual TLS with client cert verification).
    mode: tls
{% endif %}
{% endif %}
  # Describes the latency monitoring parameters.
  latency:
    # Describes the latency sampling parameters.
    sampler:
{% if loadgen_latency_sampler_prefix is defined %}
      # Prefix checks for TXs that have the given prefix.
      prefix: {{ loadgen_latency_sampler_prefix }}
{% endif %}
      # Portion of transactions to sample for latency measurement (0.0 to 1.0).
      # Lower values reduce overhead but may miss outliers. 0.01 = 1% sampling.
      portion: {{ loadgen_latency_sampler_portion | default(0.01) }}
    # Describes the latency bucket distribution.
    buckets:
      # Can be empty, uniform, or fixed.
      distribution: {{ loadgen_latency_distribution | default('uniform') }}
      # Maximum tracked latency
      max-latency: {{ loadgen_max_latency | default('5s') }}
      # Buckets amount to create between 0:max-latency
      bucket-count: {{ loadgen_latency_buckets | default(1000) }}
