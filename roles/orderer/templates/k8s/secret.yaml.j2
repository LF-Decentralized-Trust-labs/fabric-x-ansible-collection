---
apiVersion: v1
kind: Secret
metadata:
  name: {{ orderer_k8s_resource_name }}-secret
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ orderer_k8s_resource_name }}
    app.kubernetes.io/component: {{ orderer_component_type }}
    app.kubernetes.io/part-of: fabric-x-orderer
type: Opaque
data:
  msp-keystore-priv-sk: {{ lookup('file', orderer_remote_config_dir + '/msp/keystore/priv_sk') | b64encode }}
  tls-server.key: {{ lookup('file', orderer_remote_config_dir + '/tls/server.key') | b64encode }}
