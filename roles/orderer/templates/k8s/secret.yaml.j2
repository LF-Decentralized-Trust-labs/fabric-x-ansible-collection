---
apiVersion: v1
kind: Secret
metadata:
  # Secret name is scoped to this orderer instance.
  name: {{ orderer_k8s_resource_name }}-secret
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ orderer_k8s_resource_name }}
    app.kubernetes.io/component: {{ orderer_component_type }}
    app.kubernetes.io/part-of: fabric-x-orderer
type: Opaque
data:
  # Private signing key for this orderer node's MSP identity.
  msp-keystore-priv-sk: {{ lookup('file', orderer_k8s_msp_keystore_path) | b64encode }}
  # Node signing certificate issued by the organization CA.
  msp-signcert.pem: {{ lookup('file', orderer_k8s_msp_signcert_path) | b64encode }}
  # Organization CA certificate used to verify the signing cert chain.
  msp-cacert.pem: {{ lookup('file', orderer_k8s_msp_cacert_path) | b64encode }}
  # NodeOUs config: enables OU-based identity classification (admin, orderer, peer, client)
  msp-config.yaml: {{ lookup('file', orderer_k8s_msp_config_path) | b64encode }}
  # TLS private key used to authenticate this orderer during the TLS handshake.
  tls-server.key: {{ lookup('file', orderer_k8s_tls_server_key_path) | b64encode }}
  # TLS server certificate presented to connecting peers and clients.
  tls-server.crt: {{ lookup('file', orderer_k8s_tls_server_cert_path) | b64encode }}
  # TLS CA certificate used to verify incoming TLS connections.
  tls-ca.crt: {{ lookup('file', orderer_k8s_tls_ca_cert_path) | b64encode }}
