---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ orderer_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ orderer_k8s_resource_name }}
    app.kubernetes.io/component: {{ orderer_component_type }}
    app.kubernetes.io/part-of: fabric-x-orderer
spec:
  serviceName: {{ orderer_k8s_resource_name }}
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ orderer_k8s_resource_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ orderer_k8s_resource_name }}
        app.kubernetes.io/component: {{ orderer_component_type }}
        app.kubernetes.io/part-of: fabric-x-orderer
    spec:
      containers:
        - name: {{ orderer_component_type }}
          image: {{ orderer_image }}
          imagePullPolicy: {{ k8s_image_pull_policy }}
          args:
            - "{{ orderer_k8s_command }}"
            - --config=/config/node_config.yaml
          ports:
            - name: rpc
              containerPort: {{ orderer_rpc_port }}
              protocol: TCP
            - name: metrics
              containerPort: {{ orderer_metrics_port }}
              protocol: TCP
          volumeMounts:
            - name: config
              mountPath: /config/node_config.yaml
              subPath: node-config.yaml
            - name: config
              mountPath: /config/genesis.block
              subPath: genesis.block
            - name: config
              mountPath: /config/msp/signcerts/cert.pem
              subPath: msp-signcert.pem
            - name: config
              mountPath: /config/msp/cacerts/ca.crt
              subPath: msp-cacert.pem
            - name: config
              mountPath: /config/tls/server.crt
              subPath: tls-server.crt
            - name: config
              mountPath: /config/tls/ca.crt
              subPath: tls-ca.crt
            - name: secret
              mountPath: /config/msp/keystore/priv_sk
              subPath: msp-keystore-priv-sk
              readOnly: true
            - name: secret
              mountPath: /config/tls/server.key
              subPath: tls-server.key
              readOnly: true
            - name: data
              mountPath: /data
      volumes:
        - name: config
          configMap:
            name: {{ orderer_k8s_resource_name }}-config
            defaultMode: 0640
        - name: secret
          secret:
            secretName: {{ orderer_k8s_resource_name }}-secret
            defaultMode: 0600
{% if k8s_image_pull_secret %}
      imagePullSecrets:
        - name: {{ k8s_image_pull_secret }}
{% endif %}
  volumeClaimTemplates:
    - metadata:
        name: data
      spec:
        accessModes:
          - ReadWriteOnce
        storageClassName: {{ k8s_storage_class }}
        resources:
          requests:
            storage: {{ k8s_storage_size }}
