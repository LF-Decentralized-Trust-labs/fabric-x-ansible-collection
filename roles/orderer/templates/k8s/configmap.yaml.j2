---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ orderer_k8s_resource_name }}-config
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ orderer_k8s_resource_name }}
    app.kubernetes.io/component: {{ orderer_component_type }}
    app.kubernetes.io/part-of: fabric-x-orderer
data:
  node-config.yaml: |
    {{ orderer_node_config_content | indent(4) }}
  msp-signcert.pem: |
    {{ lookup('file', orderer_msp_signcert_path) | indent(4) }}
  msp-cacert.pem: |
    {{ lookup('file', orderer_msp_cacert_path) | indent(4) }}
  tls-server.crt: |
    {{ lookup('file', orderer_remote_config_dir + '/tls/server.crt') | indent(4) }}
  tls-ca.crt: |
    {{ lookup('file', orderer_remote_config_dir + '/tls/ca.crt') | indent(4) }}
binaryData:
  genesis.block: {{ lookup('file', orderer_remote_config_dir + '/genesis.block') | b64encode }}
