---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ fabric_ca_server_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ fabric_ca_server_k8s_resource_name }}
    app.kubernetes.io/component: fabric-ca
    app.kubernetes.io/part-of: fabric-ca
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ fabric_ca_server_k8s_resource_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ fabric_ca_server_k8s_resource_name }}
        app.kubernetes.io/component: fabric-ca
        app.kubernetes.io/part-of: fabric-ca
    spec:
      securityContext:
        fsGroup: {{ fabric_ca_server_k8s_fs_group }}
      containers:
        - name: fabric-ca
          image: {{ fabric_ca_image }}
          command:
            - fabric-ca-server
            - start
          env:
            - name: FABRIC_CA_HOME
              value: {{ fabric_ca_server_container_config_dir }}
          ports:
            - name: api
              containerPort: {{ fabric_ca_port }}
              protocol: TCP
            - name: operations
              containerPort: {{ fabric_ca_operations_port }}
              protocol: TCP
          volumeMounts:
            - name: config
              mountPath: {{ fabric_ca_server_container_config_dir }}/fabric-ca-server-config.yaml
              subPath: fabric-ca-server-config.yaml
              readOnly: true
            - name: secret
              mountPath: {{ fabric_ca_server_container_config_dir }}/{{ fabric_ca_server_ca_private_key_file }}
              subPath: {{ fabric_ca_server_ca_private_key_file }}
              readOnly: true
            - name: secret
              mountPath: {{ fabric_ca_server_container_config_dir }}/{{ fabric_ca_server_ca_cert_file }}
              subPath: {{ fabric_ca_server_ca_cert_file }}
              readOnly: true
{% if fabric_ca_use_tls %}
            - name: secret
              mountPath: {{ fabric_ca_server_container_config_dir }}/{{ fabric_ca_server_tls_private_key_file }}
              subPath: {{ fabric_ca_server_tls_private_key_file }}
              readOnly: true
            - name: secret
              mountPath: {{ fabric_ca_server_container_config_dir }}/{{ fabric_ca_server_tls_cert_file }}
              subPath: {{ fabric_ca_server_tls_cert_file }}
              readOnly: true
{% endif %}
{% if hostvars[postgres_db_host].postgres_use_tls is defined and hostvars[postgres_db_host].postgres_use_tls %}
            - name: config
              mountPath: {{ fabric_ca_server_container_config_dir }}/db/tls/cert.pem
              subPath: cert.pem
              readOnly: true
{% endif %}
            - name: secret
              mountPath: {{ fabric_ca_server_container_config_dir }}/IssuerPublicKey
              subPath: IssuerPublicKey
              readOnly: true
            - name: secret
              mountPath: {{ fabric_ca_server_container_config_dir }}/IssuerRevocationPublicKey
              subPath: IssuerRevocationPublicKey
              readOnly: true
            - name: secret
              mountPath: {{ fabric_ca_server_container_config_dir }}/msp/keystore/IssuerSecretKey
              subPath: IssuerSecretKey
              readOnly: true
            - name: secret
              mountPath: {{ fabric_ca_server_container_config_dir }}/msp/keystore/IssuerRevocationPrivateKey
              subPath: IssuerRevocationPrivateKey
              readOnly: true
      volumes:
        - name: secret
          secret:
            secretName: {{ fabric_ca_server_k8s_resource_name }}
            defaultMode: 0640
        - name: config
          configMap:
            name: {{ fabric_ca_server_k8s_resource_name }}
            defaultMode: 0640
{% if k8s_image_pull_secret is defined and k8s_image_pull_secret %}
      imagePullSecrets:
        - name: {{ k8s_image_pull_secret }}
{% endif %}
