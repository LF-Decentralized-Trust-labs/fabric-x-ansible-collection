---
apiVersion: v1
kind: Service
metadata:
  # LoadBalancer Service -- exposes Fabric CA outside the cluster for external clients.
  name: {{ fabric_ca_server_k8s_resource_name }}-loadbalancer
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ fabric_ca_server_k8s_resource_name }}
    app.kubernetes.io/component: fabric-ca
    app.kubernetes.io/part-of: {{ fabric_ca_server_k8s_part_of }}
spec:
  type: LoadBalancer
  selector:
    app.kubernetes.io/name: {{ fabric_ca_server_k8s_resource_name }}
  ports:
{% if fabric_ca_server_k8s_loadbalancer_expose_port %}
    - name: api
      port: {{ fabric_ca_port }}
      targetPort: api
{% endif %}
{% if fabric_ca_server_k8s_loadbalancer_expose_operations_port %}
    - name: operations
      port: {{ fabric_ca_operations_port }}
      targetPort: operations
{% endif %}
