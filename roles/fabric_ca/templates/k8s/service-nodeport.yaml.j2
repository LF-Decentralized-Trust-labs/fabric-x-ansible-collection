---
apiVersion: v1
kind: Service
metadata:
  name: {{ fabric_ca_server_k8s_resource_name }}-nodeport
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ fabric_ca_server_k8s_resource_name }}
    app.kubernetes.io/component: fabric-ca
    app.kubernetes.io/part-of: {{ fabric_ca_server_k8s_part_of }}
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: {{ fabric_ca_server_k8s_resource_name }}
  ports:
{% if fabric_ca_server_k8s_node_port is defined %}
    - name: api
      port: {{ fabric_ca_port }}
      targetPort: api
      nodePort: {{ fabric_ca_server_k8s_node_port }}
{% endif %}
{% if fabric_ca_server_k8s_operations_node_port is defined %}
    - name: operations
      port: {{ fabric_ca_operations_port }}
      targetPort: operations
      nodePort: {{ fabric_ca_server_k8s_operations_node_port }}
{% endif %}
