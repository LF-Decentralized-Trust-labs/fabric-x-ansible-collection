---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ block_explorer_ui_k8s_resource_name }}
  labels:
    app.kubernetes.io/name: {{ block_explorer_ui_k8s_resource_name }}
    app.kubernetes.io/component: block-explorer-ui
    app.kubernetes.io/part-of: {{ block_explorer_ui_k8s_part_of }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ block_explorer_ui_k8s_resource_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ block_explorer_ui_k8s_resource_name }}
        app.kubernetes.io/component: block-explorer-ui
        app.kubernetes.io/part-of: {{ block_explorer_ui_k8s_part_of }}
    spec:
      containers:
        - name: block-explorer-ui
          image: {{ block_explorer_ui_image }}
{% if k8s_resources is defined and k8s_resources %}
          resources:
{{ k8s_resources | to_nice_yaml(indent=2) | indent(12, true) }}
{% endif %}
          env:
            - name: PORT
              value: "{{ block_explorer_ui_port }}"
            - name: HOSTNAME
              value: "0.0.0.0"
            - name: BACKEND_URL
              value: "{{ block_explorer_ui_backend_url }}"
            - name: NEXT_PUBLIC_BACKEND_DISPLAY_URL
              value: "{{ block_explorer_ui_backend_url }}"
          ports:
            - name: web
              containerPort: {{ block_explorer_ui_port }}
              protocol: TCP
          readinessProbe:
            httpGet:
              path: /api/health
              port: {{ block_explorer_ui_port }}
            initialDelaySeconds: {{ k8s_readiness_probe_initial_delay_seconds | default(10) }}
            periodSeconds: {{ k8s_readiness_probe_period_seconds | default(10) }}
            timeoutSeconds: {{ k8s_readiness_probe_timeout_seconds | default(5) }}
            failureThreshold: {{ k8s_readiness_probe_failure_threshold | default(3) }}
          livenessProbe:
            httpGet:
              path: /api/health
              port: {{ block_explorer_ui_port }}
            initialDelaySeconds: {{ k8s_liveness_probe_initial_delay_seconds | default(30) }}
            periodSeconds: {{ k8s_liveness_probe_period_seconds | default(15) }}
            timeoutSeconds: {{ k8s_liveness_probe_timeout_seconds | default(5) }}
            failureThreshold: {{ k8s_liveness_probe_failure_threshold | default(5) }}
{% if k8s_image_pull_secret is defined and k8s_image_pull_secret %}
      imagePullSecrets:
        - name: {{ k8s_image_pull_secret }}
{% endif %}
