---
apiVersion: v1
kind: Service
metadata:
  name: {{ block_explorer_ui_k8s_resource_name }}-nodeport
  labels:
    app.kubernetes.io/name: {{ block_explorer_ui_k8s_resource_name }}
    app.kubernetes.io/component: block-explorer-ui
    app.kubernetes.io/part-of: {{ block_explorer_ui_k8s_part_of }}
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: {{ block_explorer_ui_k8s_resource_name }}
  ports:
{% if block_explorer_ui_k8s_node_port is defined %}
    - name: web
      port: {{ block_explorer_ui_port }}
      targetPort: web
      nodePort: {{ block_explorer_ui_k8s_node_port }}
{% endif %}
