# MSP identity for endorsing transactions
msp:
  localMspID: {{ fxconfig_msp_id }}
  configPath: {{ fxconfig_config_dir }}/msp

# Logging configuration
logging:
  # Log level specification. Can be a single level (e.g., "info", "debug") or
  # module-specific levels (e.g., "info,coordinator=debug").
  # Valid levels: debug, info, warning, error, panic, fatal.
  level: {{ fxconfig_log_level | lower }}
  # Log message format template. Supports color codes, timestamps, module names,
  # function names, and log levels. See fabric-lib-go/common/flogging for details.
  format: "{{ fxconfig_log_format }}"

# Ordering service configuration
orderer:
  address: {{ hostvars[orderer_router_host].actual_host }}:{{ hostvars[orderer_router_host].orderer_rpc_port }}
  channel: {{ channel_id }}
  connectionTimeout: {{ fxconfig_orderer_connection_timeout | default('30s') }}
{% if hostvars[orderer_router_host].orderer_use_tls is defined and hostvars[orderer_router_host].orderer_use_tls %}
  # Optional: Override parent TLS settings
  tls:
    enabled: true
    rootCerts:
      - {{ fxconfig_config_dir }}/tls/orderer/ca.crt
{% if hostvars[orderer_router_host].orderer_use_mtls is defined and hostvars[orderer_router_host].orderer_use_mtls %}
    clientCert: {{ fxconfig_config_dir }}/mtls/server.crt
    clientKey: {{ fxconfig_config_dir }}/mtls/server.key
{% endif %}
{% endif %}

# Query service configuration
queries:
  address: {{ hostvars[committer_query_service_host].actual_host }}:{{ hostvars[committer_query_service_host].committer_rpc_port }}
  connectionTimeout: {{ fxconfig_committer_query_service_connection_timeout | default('30s') }}
{% if hostvars[committer_query_service_host].committer_use_tls is defined and hostvars[committer_query_service_host].committer_use_tls %}
  # Optional: Override parent TLS settings
  tls:
    enabled: true
    rootCerts:
      - {{ fxconfig_config_dir }}/tls/committer/ca.crt
{% if hostvars[committer_query_service_host].committer_use_mtls is defined and hostvars[committer_query_service_host].committer_use_mtls %}
    clientCert: {{ fxconfig_config_dir }}/mtls/server.crt
    clientKey: {{ fxconfig_config_dir }}/mtls/server.key
{% endif %}
{% endif %}

notifications:
  address: {{ hostvars[committer_sidecar_host].actual_host }}:{{ hostvars[committer_sidecar_host].committer_rpc_port }}
  connectionTimeout: {{ fxconfig_committer_sidecar_connection_timeout | default('30s') }}
  waitingTimeout: {{ fxconfig_committer_sidecar_waiting_timeout | default('30s') }}
{% if hostvars[committer_sidecar_host].committer_use_tls is defined and hostvars[committer_sidecar_host].committer_use_tls %}
  # Optional: Override parent TLS settings
  tls:
    enabled: true
    rootCerts:
      - {{ fxconfig_config_dir }}/tls/committer/ca.crt
{% if hostvars[committer_sidecar_host].committer_use_mtls is defined and hostvars[committer_sidecar_host].committer_use_mtls %}
    clientCert: {{ fxconfig_config_dir }}/mtls/server.crt
    clientKey: {{ fxconfig_config_dir }}/mtls/server.key
{% endif %}
{% endif %}
