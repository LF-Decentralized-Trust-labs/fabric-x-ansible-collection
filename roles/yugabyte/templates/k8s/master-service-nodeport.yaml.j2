---
apiVersion: v1
kind: Service
metadata:
  # NodePort Service — exposes yb-master outside the cluster for external clients.
  name: {{ yugabyte_k8s_resource_name }}-nodeport
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ yugabyte_k8s_resource_name }}
    app.kubernetes.io/part-of: yugabyte
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: {{ yugabyte_k8s_resource_name }}
  ports:
    # RPC port used for master-to-master and tserver-to-master communication.
    - name: rpc
      port: {{ yugabyte_master_rpc_bind_port }}
      targetPort: {{ yugabyte_master_rpc_bind_port }}
      nodePort: {{ yugabyte_k8s_master_rpc_node_port }}
    # HTTP webserver port for the YB-Master admin UI.
    - name: webserver
      port: {{ yugabyte_master_webserver_port }}
      targetPort: {{ yugabyte_master_webserver_port }}
      nodePort: {{ yugabyte_k8s_master_webserver_node_port }}
