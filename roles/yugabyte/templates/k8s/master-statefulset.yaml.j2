---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  # One StatefulSet per YugabyteDB master instance.
  name: {{ yugabyte_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ yugabyte_k8s_resource_name }}
    app.kubernetes.io/part-of: {{ yugabyte_k8s_part_of }}
spec:
  # Must match the headless Service name so DNS-based pod addressing works.
  serviceName: {{ yugabyte_k8s_resource_name }}
  # One replica per master instance — scaling is done by adding nodes to the cluster.
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ yugabyte_k8s_resource_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ yugabyte_k8s_resource_name }}
        app.kubernetes.io/part-of: {{ yugabyte_k8s_part_of }}
    spec:
      containers:
        - name: yugabyte
          image: {{ yugabyte_image }}
          command:
            - bin/yb-master
            - --master_addresses={{ yugabyte_master_endpoints }}
            - --server_broadcast_addresses={{ ansible_host }}:{{ yugabyte_master_rpc_bind_port }}
            - --rpc_bind_addresses=0.0.0.0:{{ yugabyte_master_rpc_bind_port }}
            - --webserver_interface=0.0.0.0
            - --webserver_port={{ yugabyte_master_webserver_port }}
            - --replication_factor={{ yugabyte_master_hosts | length }}
            - --minloglevel={{ yugabyte_logs_level }}
            - --stderrthreshold={{ yugabyte_logs_level }}
            - --fs_data_dirs={{ yugabyte_container_data_dir }}
{% if yugabyte_use_tls %}
            - --certs_dir=/var/tls
{% endif %}
{% if yugabyte_node_to_node_use_tls %}
            - --use_node_to_node_encryption=true
{% endif %}
{% if yugabyte_client_to_server_use_tls %}
            - --allow_insecure_connections=false
            - --use_client_to_server_encryption=true
{% endif %}
{% if yugabyte_webserver_use_tls %}
            - --webserver_ca_certificate_file=/var/tls/ca.crt
            - --webserver_certificate_file=/var/tls/node.{{ ansible_host }}.crt
            - --webserver_private_key_file=/var/tls/node.{{ ansible_host }}.key
            - --webserver_redirect_http_to_https=true
{% endif %}
          ports:
            - name: rpc
              containerPort: {{ yugabyte_master_rpc_bind_port }}
              protocol: TCP
            - name: webserver
              containerPort: {{ yugabyte_master_webserver_port }}
              protocol: TCP
          readinessProbe:
            # yb-admin list_all_masters verifies that the master is responsive.
            exec:
              command:
                - /home/yugabyte/bin/yb-admin
                - --master_addresses
                - {{ yugabyte_master_endpoints }}
{% if yugabyte_client_to_server_use_tls %}
                - --certs_dir_name=/var/tls
{% endif %}
                - list_all_masters
            initialDelaySeconds: {{ k8s_readiness_probe_initial_delay_seconds | default(15) }}
            periodSeconds: {{ k8s_readiness_probe_period_seconds | default(15) }}
            timeoutSeconds: {{ k8s_readiness_probe_timeout_seconds | default(10) }}
            failureThreshold: {{ k8s_readiness_probe_failure_threshold | default(5) }}
            successThreshold: 1
          livenessProbe:
            # Same command as readiness but more lenient — detects a hung master process
            # that no longer responds to admin queries and triggers a restart.
            exec:
              command:
                - /home/yugabyte/bin/yb-admin
                - --master_addresses
                - {{ yugabyte_master_endpoints }}
{% if yugabyte_client_to_server_use_tls %}
                - --certs_dir_name=/var/tls
{% endif %}
                - list_all_masters
            initialDelaySeconds: {{ k8s_liveness_probe_initial_delay_seconds | default(60) }}
            periodSeconds: {{ k8s_liveness_probe_period_seconds | default(30) }}
            timeoutSeconds: {{ k8s_liveness_probe_timeout_seconds | default(15) }}
            failureThreshold: {{ k8s_liveness_probe_failure_threshold | default(5) }}
            successThreshold: 1
          volumeMounts:
{% if yugabyte_use_tls %}
            # CA certificate — trusted root for verifying peer certificates.
            - name: secret
              mountPath: /var/tls/ca.crt
              subPath: ca.crt
              readOnly: true
            # Node certificate — presented to clients and peers during TLS handshake.
            - name: secret
              mountPath: /var/tls/node.{{ ansible_host }}.crt
              subPath: node.{{ ansible_host }}.crt
              readOnly: true
            # Node private key — used to authenticate this master during TLS handshakes.
            - name: secret
              mountPath: /var/tls/node.{{ ansible_host }}.key
              subPath: node.{{ ansible_host }}.key
              readOnly: true
{% endif %}
            - name: data
              mountPath: {{ yugabyte_container_data_dir }}
      volumes:
        - name: secret
          secret:
            secretName: {{ yugabyte_k8s_resource_name }}-secret
            defaultMode: 0600
{% if k8s_image_pull_secret is defined and k8s_image_pull_secret %}
      imagePullSecrets:
        - name: {{ k8s_image_pull_secret }}
{% endif %}
  volumeClaimTemplates:
    # PVC name — Kubernetes appends the pod ordinal (e.g. data-<name>-0).
    - metadata:
        name: data
      spec:
        accessModes:
          - ReadWriteOnce
{% if k8s_storage_class is defined and k8s_storage_class %}
        storageClassName: {{ k8s_storage_class }}
{% endif %}
        resources:
          requests:
            storage: {{ k8s_storage_size }}
