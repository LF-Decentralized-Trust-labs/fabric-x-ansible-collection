---
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ yugabyte_k8s_resource_name }}-config
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ yugabyte_k8s_resource_name }}
    app.kubernetes.io/part-of: yugabyte
data:
{% if yugabyte_k8s_init_script_path is defined %}
  {{ yugabyte_init_script_file }}: |
    {{ lookup('file', yugabyte_k8s_init_script_path) | indent(4) }}
{% else %}
  {}
{% endif %}
