---
apiVersion: v1
kind: Service
metadata:
  # Headless Service — required by the StatefulSet for stable DNS-based pod addressing.
  name: {{ yugabyte_k8s_resource_name }}
  namespace: {{ k8s_namespace }}
  labels:
    app.kubernetes.io/name: {{ yugabyte_k8s_resource_name }}
    app.kubernetes.io/part-of: yugabyte
spec:
  # clusterIP: None makes this a headless Service — DNS resolves directly to pod IP.
  clusterIP: None
  # Required so that the headless Service DNS resolves to the pod IP even before the
  # readiness probe passes — without this, the probe itself cannot reach the pod via the
  # service hostname, creating a circular dependency that prevents the pod from ever
  # becoming ready.
  publishNotReadyAddresses: true
  selector:
    app.kubernetes.io/name: {{ yugabyte_k8s_resource_name }}
  ports:
    # YSQL (PostgreSQL-compatible) client port.
    - name: pgsql
      port: {{ yugabyte_tablet_pgsql_bind_port }}
      targetPort: {{ yugabyte_tablet_pgsql_bind_port }}
    # RPC port used for tserver-to-master and tserver-to-tserver communication.
    - name: rpc
      port: {{ yugabyte_tablet_rpc_bind_port }}
      targetPort: {{ yugabyte_tablet_rpc_bind_port }}
    # HTTP webserver port for the YB-TServer admin UI.
    - name: webserver
      port: {{ yugabyte_tablet_webserver_port }}
      targetPort: {{ yugabyte_tablet_webserver_port }}
    # HTTP webserver port for YSQL metrics and status.
    - name: pgsql-web
      port: {{ yugabyte_tablet_pgsql_web_port }}
      targetPort: {{ yugabyte_tablet_pgsql_web_port }}
    # YCQL (Cassandra-compatible) client port.
    - name: cql
      port: {{ yugabyte_tablet_cql_bind_port }}
      targetPort: {{ yugabyte_tablet_cql_bind_port }}
    # HTTP webserver port for YCQL metrics and status.
    - name: cql-web
      port: {{ yugabyte_tablet_cql_web_port }}
      targetPort: {{ yugabyte_tablet_cql_web_port }}
