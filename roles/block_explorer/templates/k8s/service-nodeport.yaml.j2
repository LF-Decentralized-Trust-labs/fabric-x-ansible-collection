---
apiVersion: v1
kind: Service
metadata:
  name: {{ block_explorer_k8s_resource_name }}-nodeport
  labels:
    app.kubernetes.io/name: {{ block_explorer_k8s_resource_name }}
    app.kubernetes.io/component: block-explorer
    app.kubernetes.io/part-of: {{ block_explorer_k8s_part_of }}
spec:
  type: NodePort
  selector:
    app.kubernetes.io/name: {{ block_explorer_k8s_resource_name }}
  ports:
{% if block_explorer_k8s_node_port is defined %}
    - name: rest
      port: {{ block_explorer_port }}
      targetPort: rest
      nodePort: {{ block_explorer_k8s_node_port }}
{% endif %}
