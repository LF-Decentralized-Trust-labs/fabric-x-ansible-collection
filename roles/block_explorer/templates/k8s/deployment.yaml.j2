---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ block_explorer_k8s_resource_name }}
  labels:
    app.kubernetes.io/name: {{ block_explorer_k8s_resource_name }}
    app.kubernetes.io/component: block-explorer
    app.kubernetes.io/part-of: {{ block_explorer_k8s_part_of }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ block_explorer_k8s_resource_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ block_explorer_k8s_resource_name }}
        app.kubernetes.io/component: block-explorer
        app.kubernetes.io/part-of: {{ block_explorer_k8s_part_of }}
    spec:
      securityContext:
        fsGroup: {{ block_explorer_k8s_fs_group }}
      containers:
        - name: block-explorer
          image: {{ block_explorer_image }}
{% if k8s_resources is defined and k8s_resources %}
          resources:
{{ k8s_resources | to_nice_yaml(indent=2) | indent(12, true) }}
{% endif %}
          args:
            - start
            - --config={{ block_explorer_container_config_dir }}/{{ block_explorer_config_file }}
          ports:
            - name: rest
              containerPort: {{ block_explorer_port }}
              protocol: TCP
          volumeMounts:
            - name: config
              mountPath: {{ block_explorer_container_config_dir }}/{{ block_explorer_config_file }}
              subPath: {{ block_explorer_config_file }}
              readOnly: true
{% if hostvars[sidecar_host].committer_use_tls is defined and hostvars[sidecar_host].committer_use_tls %}
            - name: config
              mountPath: {{ block_explorer_container_config_dir }}/tls/sidecar/ca.crt
              subPath: sidecar-ca.crt
              readOnly: true
{% endif %}
{% if hostvars[postgres_db_host].postgres_use_tls is defined and hostvars[postgres_db_host].postgres_use_tls %}
            - name: config
              mountPath: {{ block_explorer_container_config_dir }}/tls/db/ca.crt
              subPath: db-ca.crt
              readOnly: true
{% endif %}
{% if hostvars[sidecar_host].committer_use_mtls is defined and hostvars[sidecar_host].committer_use_mtls %}
            - name: secret
              mountPath: {{ block_explorer_container_config_dir }}/tls/{{ block_explorer_tls_cert_file }}
              subPath: client.crt
              readOnly: true
            - name: secret
              mountPath: {{ block_explorer_container_config_dir }}/tls/{{ block_explorer_tls_private_key_file }}
              subPath: client.key
              readOnly: true
{% endif %}
          readinessProbe:
            httpGet:
              path: /healthz
              port: {{ block_explorer_port }}
            initialDelaySeconds: {{ k8s_readiness_probe_initial_delay_seconds | default(10) }}
            periodSeconds: {{ k8s_readiness_probe_period_seconds | default(10) }}
            timeoutSeconds: {{ k8s_readiness_probe_timeout_seconds | default(5) }}
            failureThreshold: {{ k8s_readiness_probe_failure_threshold | default(3) }}
          livenessProbe:
            httpGet:
              path: /healthz
              port: {{ block_explorer_port }}
            initialDelaySeconds: {{ k8s_liveness_probe_initial_delay_seconds | default(30) }}
            periodSeconds: {{ k8s_liveness_probe_period_seconds | default(15) }}
            timeoutSeconds: {{ k8s_liveness_probe_timeout_seconds | default(5) }}
            failureThreshold: {{ k8s_liveness_probe_failure_threshold | default(5) }}
      volumes:
        - name: config
          configMap:
            name: {{ block_explorer_k8s_resource_name }}
{% if hostvars[sidecar_host].committer_use_mtls is defined and hostvars[sidecar_host].committer_use_mtls %}
        - name: secret
          secret:
            secretName: {{ block_explorer_k8s_resource_name }}
{% endif %}
{% if k8s_image_pull_secret is defined and k8s_image_pull_secret %}
      imagePullSecrets:
        - name: {{ k8s_image_pull_secret }}
{% endif %}
