---
apiVersion: v1
kind: Service
metadata:
  # LoadBalancer Service -- exposes the Block Explorer REST API and UI outside the cluster for external clients.
  name: {{ block_explorer_k8s_resource_name }}-loadbalancer
  labels:
    app.kubernetes.io/name: {{ block_explorer_k8s_resource_name }}
    app.kubernetes.io/component: block-explorer
    app.kubernetes.io/part-of: {{ block_explorer_k8s_part_of }}
spec:
  type: LoadBalancer
  selector:
    app.kubernetes.io/name: {{ block_explorer_k8s_resource_name }}
  ports:
{% if block_explorer_k8s_loadbalancer_expose_port %}
    - name: rest
      port: {{ block_explorer_port }}
      targetPort: rest
{% endif %}
{% if block_explorer_ui_k8s_loadbalancer_expose_port %}
    - name: web
      port: {{ block_explorer_ui_port }}
      targetPort: web
{% endif %}
