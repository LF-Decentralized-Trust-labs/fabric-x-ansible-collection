{%- macro render(var) -%}
{%- set var_type = var.get('type', 'str') -%}
{%- set example = namespace(found=false, val='') -%}
{%- set desc = var.get('description', []) -%}
{%- set desc_list = [desc] if desc is string else desc -%}
{%- for line in desc_list -%}
{%- if line is string and 'Example: C(' in line -%}
{%- set extracted = line | extract_c_example -%}
{%- if extracted is not none -%}
{%- set example.found = true -%}
{%- set example.val = extracted -%}
{%- endif -%}
{%- endif -%}
{%- endfor -%}
{%- if example.found -%}
{%- if var_type in ['str', 'path'] -%}
"{{ example.val }}"
{%- else -%}
{{ example.val }}
{%- endif -%}
{%- elif var_type in ['int', 'float'] -%}
1000
{%- elif var_type == 'bool' -%}
false
{%- elif var_type == 'list' -%}
{%- set elements = var.get('elements', 'str') -%}
{%- if elements in ['int', 'float'] -%}
[1000, 2000]
{%- elif elements == 'bool' -%}
[true, false]
{%- elif elements == 'dict' -%}
[{}]
{%- else -%}
["entry1", "entry2"]
{%- endif -%}
{%- elif var_type == 'dict' -%}
{}
{%- else -%}
"string"
{%- endif -%}
{%- endmacro %}
